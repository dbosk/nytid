      nytid todo import dbosk/prgi24-issues --wd ~/courses/DD1310/labs
      nytid todo import dbosk/prgi24-issues --top-level --github-labels
    """
    require_gh()
    next_id, todos = load_todos()

    <<resolve import parent and inherited metadata>>
    <<fetch github items>>
    <<filter already imported>>
