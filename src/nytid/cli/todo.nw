@cli.command(name="next")
def next_cmd(
    who: Annotated[str | None,
                   who_filter_opt] = default_username,
    headless: Annotated[bool, headless_opt] = False,
    pane: Annotated[bool, pane_opt] = False,
    window: Annotated[bool, window_opt] = False,
    block: Annotated[bool | None,
