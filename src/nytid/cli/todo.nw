):
    """add ignores another worker's later stack entry
    outside tmux."""
    save_todos(6, [
        TodoItem(
            id=1, title="My root",
            priority=5.0,
            created="2026-02-20T10:00:00",
            status="in-progress",
            labels=["mine"],
        ),
        TodoItem(
            id=5, title="Other root",
            priority=4.0,
            created="2026-02-20T10:00:00",
            status="in-progress",
            labels=["other"],
            who="other-worker",
        ),
    ])
    save_active_stack([1, 5])

    result = runner.invoke(
        cli,
        [
            "add", "-t", "My child",
            "--prio", "4.5",
