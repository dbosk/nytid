    assert child.labels == ["mine"]


def test_add_append_uses_base_priority_not_deadline_boost(
    temp_todo_dir,
):
    """--append stores base priority, not effective priority."""
    now = datetime.datetime.now()
    created = (
        now - datetime.timedelta(days=29)
    ).isoformat()
    deadline = (
        now + datetime.timedelta(days=1)
    ).isoformat()
    save_todos(3, [
        TodoItem(
            id=1, title="Stable",
            priority=5.0,
            created=created,
        ),
        TodoItem(
            id=2, title="Urgent soon",
            priority=1.0,
            created=created,
            deadline=deadline,
        ),
    ])

    # Precondition: deadline boost is active
    _, setup_todos = load_todos()
    urgent = next(
        t for t in setup_todos if t.id == 2
    )
    assert effective_priority(urgent) > urgent.priority, \
        "Test requires deadline boost to be active"

    result = runner.invoke(
        cli,
        [
            "add", "-t", "Appended",
            "--append",
            "--top-level",
        ],
    )

    assert result.exit_code == 0
    _, todos = load_todos()
    appended = next(t for t in todos if t.id == 3)
    assert appended.priority == 0.0
