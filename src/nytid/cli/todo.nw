\subsection{The [[reprioritize]] Command}

When priorities shift, a todo may need repositioning among its
siblings. This reruns the same binary search algorithm used during
[[add]], but for an existing item.  The comparison set is limited to
siblings belonging to the same worker, because cross-worker priority
comparisons are not meaningful.

An explicit ID still reprioritizes one specific item.  But omitting the
ID now serves backlog triage: we walk the current worker's unranked,
non-done items and ask the same binary-search questions for each.  We do
parents before children so that a child can use its newly ranked parent
as the upper bound of its own insertion range.

<<reprioritize command>>=
@cli.command()
def reprioritize(
    todo_id: Annotated[int | None,
                       todo_id_arg] = None,
):
    """Rerun binary search priority for a todo item.

    If no ID given, reprioritizes all current-worker
    items without numeric priority, excluding done
    items.

    Alias: reprio
    """
    next_id, todos = load_todos()
    if todo_id is None:
        targets = [
            t for t in todos
            if t.priority is None
            and t.status != "done"
            and (t.who or default_username)
            == default_username
        ]
        if not targets:
            typer.echo(
                "No unprioritized todos found for "
                f"{default_username}."
            )
            return
        targets = sort_todos_for_display(targets)
        targets.sort(
            key=lambda item: todo_depth(todos, item)
        )
        for item in targets:
            parent_ctx = next(
                (
                    t for t in todos
                    if t.id == item.parent_id
                ),
                None,
            )
            if (
                parent_ctx is not None
                and parent_ctx.priority is None
            ):
                typer.echo(
                    f"Skipping #{item.id}: parent "
                    f"#{parent_ctx.id} is still unranked."
                )
                continue
            siblings = get_active_siblings(
                todos,
                item,
                who=item.who or default_username,
                ranked_only=True,
            )
            new_priority = binary_search_priority(
                siblings,
                item,
                parent=parent_ctx,
                todos=todos,
            )
            item.priority = new_priority
            typer.echo(
                f"Reprioritized #{item.id}: "
                f"unset -> {new_priority:.1f}"
            )
        save_todos(next_id, todos)
        return
    item = next(
        (t for t in todos if t.id == todo_id), None
    )
    if item is None:
        typer.echo(
            f"Error: todo #{todo_id} not found",
            err=True,
        )
        raise typer.Exit(1)

    parent_ctx = next(
        (t for t in todos if t.id == item.parent_id),
        None,
    )
    if (
        parent_ctx is not None
        and parent_ctx.priority is None
    ):
        typer.echo(
            f"Error: cannot reprioritize #{todo_id} while "
            f"parent #{parent_ctx.id} is unranked; "
            "reprioritize the parent first",
            err=True,
        )
        raise typer.Exit(1)

    siblings = get_active_siblings(
        todos, item,
        who=item.who or default_username,
        ranked_only=True,
    )
    new_priority = binary_search_priority(
        siblings,
        item,
        parent=parent_ctx,
        todos=todos,
    )
    old_priority = item.priority
    item.priority = new_priority

    save_todos(next_id, todos)
    typer.echo(
        f"Reprioritized #{todo_id}: "
        f"{old_priority if old_priority is None else f'{old_priority:.1f}'}"
        f" -> {new_priority:.1f}"
    )
@

