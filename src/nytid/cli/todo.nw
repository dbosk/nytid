    timeout: Annotated[str | None,
                       timeout_opt] = None,
    reassign_to: Annotated[str | None,
                           reassign_opt] = default_username,
    auto_suspend: Annotated[
        bool | None, auto_suspend_opt
    ] = None,
):
    """Start the next highest-priority task.

    If the current context has an active task, start its
    next pending child. Otherwise start the highest-
    priority pending top-level task.
    """
    _, todos = load_todos()
    active = get_current_context_todo(todos, who=who)

    <<find next task to start>>

    if target is None:
        logging.warning("No matching next todo found")
        raise typer.Exit(1)

    if block is None:
        block = not (pane or window)

    start(
        todo_id=target.id,
        headless=headless,
        pane=pane,
        window=window,
        block=block,
        run=run,
        timeout=timeout,
        reassign_to=reassign_to,
        auto_suspend=auto_suspend,
    )
