    """Ensure gh CLI is available, exit with help if not."""
    if not gh_available():
        typer.echo(
            "Error: gh CLI not available. "
            "Install with: sudo apt install gh "
            "or brew install gh\n"
            "Then authenticate with: gh auth login",
            err=True,
        )
        raise typer.Exit(1)
