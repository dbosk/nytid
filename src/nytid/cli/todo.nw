Without unclamped priorities, consecutive appends would collapse to
the same value; this test verifies they remain distinguishable:

<<integration tests>>=
def test_add_append_consecutive_gets_distinct_priorities(
    temp_todo_dir,
):
    """Two consecutive --append calls produce distinct
    priorities, even below zero."""
    save_todos(2, [
        TodoItem(
            id=1, title="Only sibling",
            priority=1.0,
            created="2026-02-20T10:00:00",
        ),
    ])

    runner.invoke(
        cli,
        ["add", "-t", "First append",
         "--append", "--top-level"],
    )
    runner.invoke(
        cli,
        ["add", "-t", "Second append",
         "--append", "--top-level"],
    )
    _, todos = load_todos()
    first = next(t for t in todos if t.id == 2)
    second = next(t for t in todos if t.id == 3)
    assert first.priority == 0.0
    assert second.priority == -1.0
    assert second.priority < first.priority


