def test_seed_from_untracked_prevents_stale_stop_phantom(
    temp_tracking_dir,
):
    """Regression test for the 2026-04-05 20:36 phantom entry bug.

    With the old single-marker seed, a spurious ``pane-focus-out``
    arriving a few seconds after window creation would join the
    lone marker and later fire the trigger against a stale stop
    timestamp, producing a 2--6 second phantom history entry.  The
    self-triggering seed must leave the buffer empty so that the
    stray stop lands into a fresh buffer and waits harmlessly for
    its own partner.
    """
    who = "me"
    start_time = datetime.datetime(2026, 4, 5, 20, 36, 53)
    stale_stop_time = datetime.datetime(2026, 4, 5, 20, 36, 59)
    real_start_time = datetime.datetime(2026, 4, 5, 20, 52, 0)
    with patch(
        "nytid.cli.track.stop_tracking_labels",
    ) as mock_stop, patch(
        "nytid.cli.track.start_tracking_labels",
    ) as mock_start:
        # Seed: from-untracked, fires execute-start and truncates.
        seed_window_event_buffer(
            who, TEST_SERVER_KEY, TEST_SESSION_ID,
            [
                build_window_event_line(
                    "start",
                    ["devel", "nytid"],
                    start_time,
                    window_id="@2",
                ),
                build_window_switch_event_line(
                    target_tracked=True,
                    source_tracked=False,
                    source_window_id="@1",
                    target_window_id="@2",
                ),
            ],
        )
        mock_start.reset_mock()
        # Stray pane-focus-out arrives 6 seconds later.
        append_and_check_window_event(
            who, TEST_SERVER_KEY, TEST_SESSION_ID,
            build_window_event_line(
                "stop",
                ["devel", "nytid"],
                stale_stop_time,
                window_id="@2",
            ),
        )
        # 15 minutes later the user returns: pane-focus-in.
        append_and_check_window_event(
            who, TEST_SERVER_KEY, TEST_SESSION_ID,
            build_window_event_line(
                "start",
                ["devel", "nytid"],
                real_start_time,
                window_id="@2",
            ),
        )
    # No trigger should have fired---no marker is present in the
    # post-seed sequence, so stop_tracking_labels is never called.
    # The phantom-entry bug would have called mock_stop here with
    # end_time equal to the stale stop timestamp.
    assert mock_stop.call_count == 0
    assert mock_start.call_count == 0
