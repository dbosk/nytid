Timeout durations follow the same format as GNU [[timeout]]: a bare
number is seconds, or append [[s]], [[m]], [[h]], [[d]] for other units.
Fractional values such as [[1.5h]] (90~minutes) are accepted.

<<helper functions>>=
def parse_timeout(duration_str):
    """Parse a GNU timeout-style duration to seconds.

    Accepts bare numbers (seconds) or suffixed strings:
    ``s`` (seconds), ``m`` (minutes), ``h`` (hours),
    ``d`` (days).  Fractional values are allowed,
    e.g. ``1.5h`` for 90 minutes.
    """
    suffixes = {
        "s": 1, "m": 60,
        "h": 3600, "d": 86400,
    }
    if duration_str[-1] in suffixes:
        return float(duration_str[:-1]) \
            * suffixes[duration_str[-1]]
    return float(duration_str)
@

<<helper functions>>=
def validate_tmux_options(
    pane: bool, window: bool
) -> None:
    """Reject invalid tmux option combinations."""
    if pane and window:
        raise ValueError(
            "Error: --pane and --window are mutually exclusive"
        )
    if (pane or window) and not os.environ.get("TMUX"):
        raise ValueError(
            "Error: --pane/--window require an active tmux session"
        )


def join_tracking_labels(labels: List[str]) -> str:
    """Return labels joined for prompts and tmux names."""
    return " ".join(labels)


def build_tracking_prompt_prefix(
    labels: List[str],
) -> str:
    """Return the prompt prefix for a tracked shell."""
    label_text = join_tracking_labels(labels)
    if label_text:
        return f"track:{label_text}"
    return "track"


def build_tracking_shell_command(
    labels: List[str],
    env: Dict[str, str],
) -> tuple[List[str], Optional[str], Optional[str]]:
    """Return a shell command with a prompt showing the labels."""
    shell = env.get("SHELL") or os.environ.get(
        "SHELL", "/bin/sh"
    )
    shell_name = os.path.basename(shell)
    prefix = build_tracking_prompt_prefix(labels)

    if shell_name == "bash":
        with tempfile.NamedTemporaryFile(
            mode="w", suffix=".sh", delete=False
        ) as f:
            f.write(
                "[ -f ~/.bashrc ] && source ~/.bashrc\n"
            )
            f.write(f'PS1="{prefix} $PS1"\n')
        return [shell, "--init-file", f.name], f.name, None

    if shell_name == "zsh":
        prompt_dir = tempfile.mkdtemp()
        with open(
            os.path.join(prompt_dir, ".zshrc"), "w"
        ) as f:
            f.write(
                "[ -f ~/.zshrc ] && source ~/.zshrc\n"
            )
            f.write(f'PS1="{prefix} $PS1"\n')
        env["ZDOTDIR"] = prompt_dir
        return [shell], None, prompt_dir

    if "PS1" in env:
        env["PS1"] = f"{prefix} {env['PS1']}"
    else:
        env["PS1"] = f"{prefix} \\w\\n$ "

    return [shell], None, None


def cleanup_tracking_shell_command(
    prompt_file: Optional[str],
    prompt_dir: Optional[str],
) -> None:
    """Remove temporary prompt artifacts for tracked shells."""
    if prompt_file is not None:
        try:
            os.unlink(prompt_file)
        except OSError:
            pass

    if prompt_dir is not None:
        try:
            os.unlink(
                os.path.join(prompt_dir, ".zshrc")
            )
        except OSError:
            pass
        try:
            os.rmdir(prompt_dir)
        except OSError:
            pass


def make_tmux_channel(prefix: str) -> str:
    """Return a unique tmux wait-for channel name."""
    return (
        f"nytid-{prefix}-"
        f"{os.getpid()}-{time.time_ns()}"
    )


def make_tmux_completion_guard(
    status_file: Optional[str],
) -> Optional[str]:
    """Return the atomic completion guard path."""
    if status_file is None:
        return None
    return status_file + ".guard"


def build_tmux_completion_shell(
    *,
    status_file: Optional[str] = None,
    wait_channel: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
    completion_guard: Optional[str] = None,
    status_arg: str,
    signal_arg: str,
) -> str:
    """Return shell code for one-shot tmux completion."""
    shell_commands = []

    if status_file is not None:
        shell_commands.append(
            "printf 'status=%s\\nsignal=%s\\n' "
            f"{status_arg} {signal_arg} "
            f"> {shlex.quote(status_file)}"
        )
    if on_exit_shell is not None:
        shell_commands.append(on_exit_shell)
    if wait_channel is not None:
        shell_commands.append(
            "tmux wait-for -S " + shlex.quote(wait_channel)
        )

    body = "; ".join(shell_commands) or ":"
    if completion_guard is None:
        return body
    return (
        f"if mkdir {shlex.quote(completion_guard)} 2>/dev/null; then "
        f"{body}; "
        "fi"
    )


def build_tmux_wait_wrapper(
    command_args: List[str],
    ready_channel: str,
    *,
    status_file: Optional[str] = None,
    wait_channel: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
    completion_guard: Optional[str] = None,
) -> List[str]:
    """Return a wrapper that waits and records normal exit."""
    script_parts = [
        f"tmux wait-for {shlex.quote(ready_channel)} || exit $?",
        '"$@"',
        "status=$?",
    ]
    completion_shell = build_tmux_completion_shell(
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
        status_arg='"$status"',
        signal_arg="''",
    )
    if completion_shell != ":":
        script_parts.append(completion_shell)
    script_parts.append('exit "$status"')
    return [
        "/bin/sh",
        "-c",
        "; ".join(script_parts),
        "sh",
    ] + command_args


def build_tmux_hook_command(
    *,
    status_file: Optional[str] = None,
    wait_channel: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
    completion_guard: Optional[str] = None,
) -> str:
    """Build the tmux hook command for abnormal pane exit."""
    shell_command = build_tmux_completion_shell(
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
        status_arg=shlex.quote("#{pane_dead_status}"),
        signal_arg=shlex.quote("#{pane_dead_signal}"),
    )
    if shell_command == ":":
        return ""
    return "run-shell " + shlex.quote(shell_command)


def install_tmux_exit_hooks(
    pane_id: str,
    hook_command: str,
) -> None:
    """Install pane exit hooks for a newly created pane."""
    if not hook_command:
        return
    for hook_name in ("pane-exited", "pane-died"):
        subprocess.run(
            [
                "tmux",
                "set-hook",
                "-p",
                "-t",
                pane_id,
                hook_name,
                hook_command,
            ],
            check=True,
        )


def parse_tmux_exit_status(text: str) -> int:
    """Parse tmux hook status text into a shell exit code."""
    data = {}
    for line in text.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        data[key] = value

    signal_str = data.get("signal", "")
    if signal_str:
        return 128 + int(signal_str)

    status_str = data.get("status", "")
    if status_str:
        return int(status_str)

    return 1


def read_tmux_exit_status(status_file: str) -> int:
    """Read the exit code recorded by the tmux hook."""
    try:
        with open(status_file) as f:
            return parse_tmux_exit_status(f.read())
    except OSError:
        return 1


def run_tmux_command(
    command_args: List[str],
    *,
    cwd: str,
    env: Dict[str, str],
    window: bool = False,
    window_name: Optional[str] = None,
    block: bool = True,
    exit_status_file: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
) -> Optional[int]:
    """Run a command in tmux and optionally wait for exit."""
    ready_channel = make_tmux_channel("ready")
    wait_channel = None
    status_file = exit_status_file
    pane_id = None
    remove_status_file = False
    completion_guard = None

    if block and status_file is None:
        fd, status_file = tempfile.mkstemp(
            prefix="nytid-tmux-",
            suffix=".status",
        )
        os.close(fd)
        remove_status_file = True
    if block:
        wait_channel = make_tmux_channel("done")
        completion_guard = make_tmux_completion_guard(
            status_file
        )

    wrapped_command = build_tmux_wait_wrapper(
        command_args,
        ready_channel,
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
    )

    hook_command = build_tmux_hook_command(
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
    )

    tmux_args = [
        "tmux",
        "new-window" if window else "split-window",
        "-P",
        "-F",
        "#{pane_id}",
    ]
    for key, value in sorted(env.items()):
        tmux_args.extend([
            "-e",
            f"{key}={value}",
        ])
    if window and window_name:
        tmux_args.extend(["-n", window_name])
    tmux_args.extend([
        "-c",
        cwd,
    ])
    tmux_args.append(shlex.join(wrapped_command))

    old_sigint = None
    if block:
        old_sigint = signal.signal(
            signal.SIGINT, signal.SIG_IGN
        )

    try:
        result = subprocess.run(
            tmux_args,
            check=True,
            capture_output=True,
            text=True,
        )
        pane_id = result.stdout.strip()
        install_tmux_exit_hooks(pane_id, hook_command)
        subprocess.run(
            ["tmux", "wait-for", "-S", ready_channel],
            check=True,
        )
        if not block:
            return None
        subprocess.run(
            ["tmux", "wait-for", wait_channel],
            check=True,
        )
        return read_tmux_exit_status(status_file)
    except Exception:
        if pane_id:
            try:
                subprocess.run(
                    ["tmux", "kill-pane", "-t", pane_id],
                    check=False,
                )
            except OSError:
                pass
        raise
    finally:
        if block and old_sigint is not None:
            signal.signal(signal.SIGINT, old_sigint)
        if remove_status_file and status_file is not None:
            try:
                os.unlink(status_file)
            except OSError:
                pass
        if completion_guard is not None:
            try:
                os.rmdir(completion_guard)
            except OSError:
                pass
@

When [[--no-block]] is used, the tmux pane needs to call
[[nytid track stop]] after the child exits.  We build a shell command
that invokes [[track stop]] with the correct labels and worker identity.
The strategy mirrors [[todo]]'s [[build_detached_todo_finalize_command]],
but is simpler because [[track stop]] already handles all the session
bookkeeping.

<<helper functions>>=
def build_detached_track_finalize_command(
    labels, who
):
    """Return shell command to stop tracking
    when pane exits."""
    pythonpath = os.path.abspath(
        os.path.join(
            os.path.dirname(__file__),
            "..", "..", "..",
        )
    )
    label_args = " ".join(
        shlex.quote(l) for l in labels
    )
    cmd = (
        f"PYTHONPATH={shlex.quote(pythonpath)} "
        f"{shlex.quote(sys.executable)} "
        "-c 'from nytid.cli.track import cli;"
        " cli()' "
        f"stop {label_args}"
    )
    if who != default_username:
        cmd += f" --who {shlex.quote(who)}"
    return cmd
@

\subsection{Blocking Command Execution}

When [[start]] launches a command, it must stop the labels afterwards no
matter how the child terminates.  That includes normal exit, an error code,
and signals such as Ctrl+C.

\paragraph{Signal handling.}
Pressing Ctrl+C in a terminal sends \textsc{sigint} to the entire
foreground \emph{process group}, which includes both nytid and the
child.  Without special handling the Python runtime raises
[[KeyboardInterrupt]] in the parent at the same moment the child
receives the signal, interrupting the tracking bookkeeping before
it has a chance to complete.

The correct POSIX approach is to ignore \textsc{sigint} in the
parent for the duration of the child's execution.
[[subprocess.run]] applies [[restore_signals=True]] by default,
which resets any [[SIG_IGN]] signals to [[SIG_DFL]] in the child
before [[exec]]---so the child still terminates on Ctrl+C as
expected, while the parent continues executing and stops the
session cleanly.  The original handler is restored in a [[finally]]
clause so it is always reinstated even if the child raises another
exception.

The tmux variants preserve the same contract.  They still block until the
tracked process ends, but the waiting happens through tmux pane hooks rather
than by waiting directly on the child process in the current terminal.

We keep the launch path split into four phases so the lifecycle is visible in
the literate source: announce what is about to happen, run the child, stop the
labels that were started for that launch, and report the result.

<<launch subprocess if requested>>=
if launch_requested:
    launch_start_time = datetime.datetime.now()
    <<announce launch>>
    <<run launched process>>
    if exit_code is None:
        typer.echo(
            "Tracking will stop automatically "
            "when the pane exits."
        )
        raise typer.Exit(0)
    <<stop launched labels>>
    <<report launch result>>
    raise typer.Exit(exit_code)
@

<<announce launch>>=
