def test_should_auto_suspend_cli_flag_wins(
    temp_tracking_dir,
):
    """CLI flag overrides all config."""
    assert should_auto_suspend("me", True) is True
    assert should_auto_suspend("me", False) is False

def test_should_auto_suspend_per_worker_config(
    temp_tracking_dir,
):
    """Per-worker config overrides global."""
    import typerconf as config
    config.set(
        f"{AUTO_SUSPEND_CONFIG}.default", "true"
    )
    config.set(
        f"{AUTO_SUSPEND_CONFIG}.alice", "false"
    )
    assert should_auto_suspend("alice", None) is False
    # Other worker falls through to global
    assert should_auto_suspend("bob", None) is True

def test_should_auto_suspend_global_config(
    temp_tracking_dir,
):
    """Global config overrides hard-coded default."""
    import typerconf as config
    config.set(
        f"{AUTO_SUSPEND_CONFIG}.default", "false"
    )
    assert should_auto_suspend("me", None) is False

def test_should_auto_suspend_hardcoded_default(
    temp_tracking_dir,
):
    """Hard-coded default is True when no config is set.

    Earlier tests may have set config keys that persist
    in the same process (typerconf has no delete method),
    so we mock [[config.get]] to always raise [[KeyError]]
    for auto-suspend keys.
    """
    import typerconf as _cfg
    _orig_get = _cfg.get
    def _no_auto_suspend(key, *args, **kwargs):
        if key.startswith(AUTO_SUSPEND_CONFIG):
            raise KeyError(key)
        return _orig_get(key, *args, **kwargs)
    with patch(
        "nytid.cli.track.config.get",
        side_effect=_no_auto_suspend,
    ):
        assert should_auto_suspend("me", None) is True
