def test_build_tmux_wait_wrapper_signals_done_once():
    """Wrapper records normal exit and wakes waiters."""
    status_file = "/tmp/nytid.status"
    guard = make_tmux_completion_guard(status_file)

    wrapper = build_tmux_wait_wrapper(
        ["python", "-V"],
        "ready-chan",
        status_file=status_file,
        wait_channel="done-chan",
        on_exit_shell="cleanup-command",
        completion_guard=guard,
    )

    assert wrapper[:3] == ["/bin/sh", "-c", wrapper[2]]
    assert "tmux wait-for ready-chan" in wrapper[2]
    assert "status=$?" in wrapper[2]
    assert "mkdir /tmp/nytid.status.guard" in wrapper[2]
    assert "printf 'status=%s\\nsignal=%s\\n' \"$status\" ''" in (
        wrapper[2]
    )
    assert "cleanup-command" in wrapper[2]
    assert "tmux wait-for -S done-chan" in wrapper[2]
    assert wrapper[3:] == ["sh", "python", "-V"]


def test_build_tmux_hook_command_uses_guarded_run_shell():
    """Pane exit hooks become a guarded fallback path."""
    hook = build_tmux_hook_command(
        status_file="/tmp/nytid.status",
        wait_channel="done-chan",
        on_exit_shell="cleanup-command",
        completion_guard="/tmp/nytid.status.guard",
    )

    assert hook.startswith("run-shell ")
    assert "mkdir /tmp/nytid.status.guard" in hook
    assert "#{pane_dead_status}" in hook
    assert "#{pane_dead_signal}" in hook
    assert "cleanup-command" in hook
    assert "tmux wait-for -S done-chan" in hook

