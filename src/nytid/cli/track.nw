def resolve_tracking_entry(
    entries: List[TrackingEntry],
    hash_prefix: str,
) -> TrackingEntry:
    """Resolve a unique history entry from a hash prefix."""
    matches = [
        entry for entry in entries
        if entry.content_hash().startswith(hash_prefix)
    ]
    if not matches:
        raise ValueError(f"No tracking entry matches '{hash_prefix}'")
    if len(matches) > 1:
        raise ValueError(
            f"Tracking entry hash '{hash_prefix}' is ambiguous"
        )
    return matches[0]

def replace_tracking_entry(
    entries: List[TrackingEntry],
    original: TrackingEntry,
    updated: TrackingEntry,
) -> List[TrackingEntry]:
    """Return a copy with one historical entry replaced."""
    replaced = False
    result = []
    for entry in entries:
        if not replaced and entry.content_hash() == original.content_hash():
            result.append(updated)
            replaced = True
        else:
            result.append(entry)
    if not replaced:
        raise ValueError(
            f"No tracking entry matches '{original.content_hash()}'"
        )
    return result

def remove_tracking_entry(
    entries: List[TrackingEntry],
    target: TrackingEntry,
) -> List[TrackingEntry]:
    """Return a copy with one historical entry removed."""
    removed = False
    result = []
    target_hash = target.content_hash()
    for entry in entries:
        if not removed and entry.content_hash() == target_hash:
            removed = True
            continue
        result.append(entry)
    if not removed:
        raise ValueError(f"No tracking entry matches '{target_hash}'")
    return result

<<load tracking data>>=
def load_tracking_data() -> List[TrackingEntry]:
    """
    Load historical tracking data from the persistent storage file.
    
    Returns:
        List of TrackingEntry objects, or empty list if file doesn't exist
        or contains invalid data
    """
    entries = load_tracking_data_raw()
    normalized_entries, _ = normalize_tracking_entries(entries)
    return normalized_entries

def save_tracking_data(entries: List[TrackingEntry]):
    """
    Save tracking data to persistent storage.
    
    Args:
        entries: List of TrackingEntry objects to save
    """
    def persist(_entries):
        return entries

    mutate_tracking_history(persist)

def add_completed_entries(new_entries: List[TrackingEntry]):
    """
    Add newly completed entries to the historical tracking data.
    
    This function implements an append-only approach to maintain data integrity.
    It loads existing data, appends new entries, and saves the combined dataset.
    
    Args:
        new_entries: List of TrackingEntry objects to add to historical data
    """
    if not new_entries:
        return

    def update_history(existing_entries):
        existing_entries.extend(new_entries)
        return existing_entries

    mutate_tracking_history(update_history)
@

\subsection{Active Session Management}

The active session maintains the current tracking state and survives
application restarts. To support multi-worker parallel tracking, each
worker gets an independent session file. The filename includes a
sanitized version of the worker name: for the default worker this is
[[current_session_<sanitize($USER)>.json]], while a worker such as
\enquote{Dan-Claude} gets [[current_session_dan-claude.json]]. This
avoids conflicts when two workers track time simultaneously.

For backward compatibility, if the old [[current_session.json]] file
exists and no per-worker file is found for \enquote{me}, the system
loads from the old file. This means existing users continue working
without any migration step.

<<session management>>=
def load_active_session(who: str = None) -> ActiveSession:
    """
    Load the current active session from persistent storage.

    Args:
        who: Worker identity (default $USER)

    Returns:
        ActiveSession object with restored state, or empty
        session if file doesn't exist or contains invalid data
    """
    session_file = get_current_session_file(who)
    if not session_file.exists():
        return ActiveSession()

    try:
        with open(session_file, 'r') as f:
            data = json.load(f)
            return ActiveSession.from_dict(data)
    except (json.JSONDecodeError, KeyError, ValueError) as e:
        logging.warning(
            f"Error loading active session from "
            f"{session_file}: {e}"
        )
        return ActiveSession()

def save_active_session(
    session: ActiveSession,
    who: str = None
):
    """
    Save the current active session to persistent storage.

    Args:
        session: ActiveSession object to save
        who: Worker identity (default $USER)
    """
    ensure_tracking_dir()
    session_file = get_current_session_file(who)
    with open(session_file, 'w') as f:
        json.dump(session.to_dict(), f, indent=2)

@

Tracking state lives in two files---the per-worker session and the
shared history log---so any mutation must hold both locks to prevent
a concurrent process from seeing a half-written state.
[[mutate_worker_tracking_state]] acquires the session lock first
(per-worker), then the history lock (global), loads fresh copies of
both files, and hands them to a \emph{callback}.  The callback
returns the updated session and history (plus optional extras), and
the function writes both files before releasing the locks.

The callback pattern keeps the critical section explicit: all reads
and writes happen inside the lock, so callers cannot accidentally
read stale data before locking or forget to write afterwards.

Normalization runs twice---once before the callback (so the
callback sees clean data) and once after (so any entries the
callback appended are normalized before they hit disk).  The
double pass is intentional: callbacks may construct entries by hand
rather than going through [[ActiveSession.stop_labels]], so a
post-callback pass ensures invariants hold regardless.

<<session management>>=
def mutate_worker_tracking_state(
    callback,
    who: str = None,
):
    """Mutate one worker's session and history under shared locks."""
    ensure_tracking_dir()
    session_lock_file = get_current_session_lock_file(who)
    with open(session_lock_file, 'w') as session_lock_handle:
        fcntl.flock(session_lock_handle, fcntl.LOCK_EX)
        lock_file = get_tracking_lock_file()
        with open(lock_file, 'w') as history_lock_handle:
            fcntl.flock(history_lock_handle, fcntl.LOCK_EX)
            try:
                session = load_active_session(who)
                entries = load_tracking_data_raw()
                normalized_entries, _ = normalize_tracking_entries(entries)
                callback_result = callback(
                    session,
                    normalized_entries,
                )
                if isinstance(callback_result, tuple):
                    updated_session = callback_result[0]
                    updated_entries = callback_result[1]
                    extra = callback_result[2:]
                else:
                    updated_session = session
                    updated_entries = normalized_entries
                    extra = ()
                final_entries, _ = normalize_tracking_entries(
                    updated_entries
                )
                save_active_session(updated_session, who)
                save_tracking_data_unlocked(final_entries)
                if extra:
                    return (
                        updated_session,
                        final_entries,
                        *extra,
                    )
                return updated_session, final_entries
            finally:
                fcntl.flock(history_lock_handle, fcntl.LOCK_UN)
                fcntl.flock(session_lock_handle, fcntl.LOCK_UN)

@

[[start_tracking_labels]] is the public entry point for beginning a
tracking session.  It wraps [[mutate_worker_tracking_state]] so that
the caller never touches locks directly.  When [[replace]] is true,
any labels that are already active are discarded (their incomplete
entries thrown away) before being restarted---this supports the
\enquote{restart timer} idiom without requiring an explicit stop first.

<<session management>>=
def start_tracking_labels(
    labels: List[str],
    *,
    start_time: datetime.datetime,
    who: str = None,
    replace: bool = False,
    description: Optional[str] = None,
    update_tmux_context: bool = True,
):
    """Start labels from fresh on-disk state."""
    normalized_labels = list(labels)

    def update(session, history_entries):
        discarded = []
        if replace:
            to_discard = [
                label for label in normalized_labels
                if session.get_label_info(label) is not None
            ]
            discarded = session.discard_labels(to_discard)

        started = session.start_labels(normalized_labels, start_time)
        if description is not None:
            for label in started:
                if label not in session.active_labels:
                    continue
                label_start_time, _, batch_id = (
                    session.active_labels[label]
                )
                session.active_labels[label] = (
                    label_start_time,
                    description,
                    batch_id,
                )
        already_tracking = [
            label for label in normalized_labels
            if label not in started
        ]
        return (
            session,
            history_entries,
            started,
            already_tracking,
            discarded,
        )

    _, _, started, already_tracking, discarded = (
        mutate_worker_tracking_state(update, who)
    )
    if update_tmux_context and started:
        resolved_who = (
            who if who is not None
            else default_username
        )
        register_tmux_context_labels(
            started, resolved_who,
        )
    return started, already_tracking, discarded

@

[[stop_tracking_labels]] is the symmetric counterpart: it stops labels
and appends the completed entries to the history log, all under lock.
Three modes are supported: stop specific [[labels]], stop
[[all_labels]], or stop the most recent batch (the default).  Passing
[[labels=[]]] (an empty list) is a deliberate no-op---distinct from
[[labels=None]], which triggers the batch-stop path.  This distinction
matters when a caller has filtered a candidate list down to nothing;
the empty list means \enquote{I chose these specific labels and there
are zero}, not \enquote{please stop the batch}.

The todo wrapper needs one more operation: stop a specific label and,
optionally, a few companion labels, but only if they are currently
active and not protected by some higher-level policy.  Rather than let
[[cli.todo]] open-code session mutation, we expose a second public
helper here.  That keeps all on-disk tracking writes behind the same
locking API and lets todo orchestration remain a thin wrapper around
track semantics.

The distinction from [[stop_tracking_labels]] is intentional.
[[stop_tracking_labels]] models the user-facing [[track stop]] command:
it treats \enquote{none of those labels are active} as an error unless
the caller explicitly asks for silence.  The todo wrapper needs a softer
variant.  Its job is to say \enquote{if [[todo:7]] is active, stop it
now}; if that label is already
gone, todo bookkeeping should still succeed.  By exposing that softer
operation here, we keep the policy difference explicit without forcing
[[cli.todo]] to reimplement locking, history updates, or session writes.

The helper itself is deliberately narrow.  Callers provide the full set
of candidate labels, and the helper filters that set against the active
session under lock before stopping anything.  That makes wrapper code
robust against small races and repeated cleanup paths: labels that are
already gone are ignored, while labels that are still active are stopped
and recorded through the normal tracking-history machinery.

<<session management>>=
def stop_tracking_labels(
    *,
    who: str = None,
    labels: Optional[List[str]] = None,
    all_labels: bool = False,
    end_time: Optional[datetime.datetime] = None,
    quiet_if_missing: bool = False,
    update_tmux_context: bool = True,
):
    """Stop labels from fresh on-disk state."""
    if end_time is None:
        end_time = datetime.datetime.now()

    def update(session, history_entries):
        if all_labels:
            completed_entries = session.stop_labels(
                count=len(session.label_order),
                end_time=end_time,
                who=who,
            )
        elif labels is not None:
            completed_entries = session.stop_labels(
                labels,
                end_time,
                who=who,
            )
        else:
            completed_entries = session.stop_labels(
                end_time=end_time,
                stop_batch=True,
                who=who,
            )

        updated_entries = list(history_entries)
        updated_entries.extend(completed_entries)
        return session, updated_entries, completed_entries

    session, _, completed_entries = mutate_worker_tracking_state(
        update,
        who,
    )

    if update_tmux_context and completed_entries:
        stopped_labels = [
            label
            for entry in completed_entries
            for label in entry.labels
        ]
        resolved_who = (
            who if who is not None
            else default_username
        )
        unregister_tmux_context_labels(
            stopped_labels, resolved_who,
        )

    if completed_entries:
        return session, completed_entries
    if quiet_if_missing:
        return session, []
    if labels:
        raise ValueError(
            "None of the specified labels are currently tracking: "
            f"{', '.join(labels)}"
        )
    raise ValueError("No active tracking to stop")


def stop_tracking_labels_if_active(
    *,
    who: str = None,
    labels: List[str],
    end_time: Optional[datetime.datetime] = None,
    update_tmux_context: bool = True,
):
    """Stop the active subset of ``labels`` without erroring if absent."""
    if end_time is None:
        end_time = datetime.datetime.now()

    active_labels = []

    def update(session, history_entries):
        to_stop = [
            label for label in labels
            if label in session.get_active_labels()
        ]
        if not to_stop:
            return session, history_entries, []

        completed_entries = session.stop_labels(
            to_stop,
            end_time,
            who=who,
        )
        active_labels.extend(to_stop)
        updated_entries = list(history_entries)
        updated_entries.extend(completed_entries)
        return session, updated_entries, completed_entries

    session, _, completed_entries = mutate_worker_tracking_state(
        update,
        who,
    )
    if update_tmux_context and completed_entries:
        stopped_labels = [
            label
            for entry in completed_entries
            for label in entry.labels
        ]
        resolved_who = (
            who if who is not None
            else default_username
        )
        unregister_tmux_context_labels(
            stopped_labels, resolved_who,
        )
    return session, completed_entries, active_labels

def update_switch_other_labels(
    labels: Optional[List[str]],
    *,
    who: str = None,
):
    """Persist the saved switch target without touching active labels."""

    if who is None:
        who = default_username

    def update(session, history_entries):
        session.switch_other = labels
        return session, history_entries

    mutate_worker_tracking_state(update, who)
