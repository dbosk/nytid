def test_add_manual_entry(temp_tracking_dir):
    """Test adding a manual time entry"""
    result = runner.invoke(cli, [
        "add", "DD1310", "grading",
        "--duration", "1",
        "--description", "Test grading"
    ])
    assert result.exit_code == 0
    assert "Added entry: DD1310, grading" in result.stdout
    assert "1h 0m 0s" in result.stdout

def test_add_error_cases(temp_tracking_dir):
    """Test add command error conditions"""
    # Try to add with invalid duration
    result = runner.invoke(cli, [
        "add", "DD1310", "--duration", "0"
    ])
    assert result.exit_code == 1
    assert "Duration must be positive" in result.stdout

def test_add_with_offset(temp_tracking_dir):
    """--offset backdates the start of an added entry."""
    result = runner.invoke(cli, [
        "add", "meeting",
        "--duration", "30m",
        "--offset", "-60m"
    ])
    assert result.exit_code == 0
    assert "Added entry: meeting" in result.stdout
    # Start time should be ~60 min ago, end ~30 min ago.
    entries = load_tracking_data()
    assert len(entries) == 1
    delta_start = datetime.datetime.now() - entries[0].start_time
    delta_end = datetime.datetime.now() - entries[0].end_time
    assert 55 * 60 < delta_start.total_seconds() < 65 * 60
    assert 25 * 60 < delta_end.total_seconds() < 35 * 60

def test_add_with_at_time(temp_tracking_dir):
    """--at sets an explicit start time for an added entry."""
    result = runner.invoke(cli, [
        "add", "meeting",
        "--duration", "45m",
        "--at", "2024-06-15 10:00"
    ])
    assert result.exit_code == 0
    entries = load_tracking_data()
    assert len(entries) == 1
    assert entries[0].start_time == datetime.datetime(2024, 6, 15, 10, 0)
    assert entries[0].end_time == datetime.datetime(2024, 6, 15, 10, 45)

def test_add_offset_and_at_are_exclusive(temp_tracking_dir):
    """Using both --offset and --at together is an error."""
    result = runner.invoke(cli, [
        "add", "meeting",
        "--duration", "30m",
        "--offset", "-60m",
        "--at", "14:00"
    ])
    assert result.exit_code == 1
    assert "Cannot use both --offset and --at" in result.stdout
@

\section{Comprehensive Testing}

All test functions are defined alongside their corresponding implementation
sections throughout this document using the [[<<test functions>>]] chunk,
which is concatenated as we progress through the document. This follows
literate programming best practices by keeping tests close to the code
they validate.

Every test function takes a [[temp_tracking_dir]] fixture that redirects
all tracking I/O into a temporary directory.  The fixture is defined in
[[conftest.py]] (\cref{conftest}) so that other modules whose tests
interact with the tracking layer---such as [[todo]]
(\cref{cli.todo})---can reuse it without duplicating the patching logic.

