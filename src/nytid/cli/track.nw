Todo and track both describe shell context as a namespace plus the values
that identify the current work.  The same rendered string appears in
[[PS1]] and, for tmux windows, in the window name.  We therefore build
that context string once and let both commands reuse it.

<<helper functions>>=
def join_context_values(values: List[str]) -> str:
    """Return context values joined for prompts and tmux names."""
    return " ".join(values)


def build_context_name(
    prefix: str,
    values: List[str],
) -> str:
    """Return a prefixed context label for prompts and tmux names."""
    value_text = join_context_values(values)
    if value_text:
        return f"{prefix}:{value_text}"
    return prefix


def apply_context_prompt(
    context_name: str,
    env: Dict[str, str],
) -> None:
    """Store a context marker in [[env]] for child shells."""
    if "PS1" in env:
        env["PS1"] = f"{context_name} {env['PS1']}"
    else:
        env["PS1"] = f"{context_name} \\w\\n$ "
@


Tmux shell launches need a different helper from direct interactive
subprocesses.  In tmux we want the user's normal shell startup path so
that [[~/.bashrc]], completion, and other interactive customisations load
exactly as they do in an ordinary window.  Todo and track therefore
share one helper that simply resolves the default shell command.

<<helper functions>>=
def build_plain_shell_command(
    env: Dict[str, str],
) -> List[str]:
    """Return the plain shell command for interactive tmux launches."""
    shell = env.get("SHELL") or os.environ.get(
        "SHELL", "/bin/sh"
    )
    return [shell]
@


Direct interactive subprocesses still need one extra trick: run the
user's usual shell init files, then prepend a context marker to the
prompt without losing tab completion or other interactive setup.  We
therefore keep a separate helper for the non-tmux case.

<<helper functions>>=
def build_prompted_shell_command(
    prefix: str,
    env: Dict[str, str],
) -> tuple[List[str], Optional[str], Optional[str]]:
    """Return a shell command with a prefixed prompt."""
    shell = env.get("SHELL") or os.environ.get(
        "SHELL", "/bin/sh"
    )
    shell_name = os.path.basename(shell)
    if shell_name == "bash":
        with tempfile.NamedTemporaryFile(
            mode="w", suffix=".sh", delete=False
        ) as f:
            f.write(
                "[ -f ~/.bashrc ] && source ~/.bashrc\n"
            )
            f.write(f'PS1="{prefix} $PS1"\n')
        return [shell, "--init-file", f.name], f.name, None

    if shell_name == "zsh":
        prompt_dir = tempfile.mkdtemp()
        with open(
            os.path.join(prompt_dir, ".zshrc"), "w"
        ) as f:
            f.write(
                "[ -f ~/.zshrc ] && source ~/.zshrc\n"
            )
            f.write(f'PS1="{prefix} $PS1"\n')
        env["ZDOTDIR"] = prompt_dir
        return [shell], None, prompt_dir

    apply_context_prompt(prefix, env)

    return [shell], None, None
@


Cleanup belongs next to construction because the temporary bash init
file or zsh [[ZDOTDIR]] directory must be removed by both callers.

<<helper functions>>=
def cleanup_prompted_shell_command(
    prompt_file: Optional[str],
    prompt_dir: Optional[str],
) -> None:
    """Remove temporary prompt artifacts for prefixed shells."""
    if prompt_file is not None:
        try:
            os.unlink(prompt_file)
        except OSError:
            pass

    if prompt_dir is not None:
        try:
            os.unlink(
                os.path.join(prompt_dir, ".zshrc")
            )
        except OSError:
            pass
        try:
            os.rmdir(prompt_dir)
        except OSError:
            pass


@


Detached tmux launches need two extra pieces of coordination beyond the
normal subprocess case.  First, each launch needs a unique channel name
so the parent can wait for the correct completion signal.  Second, the
child needs an atomic guard file so completion is recorded exactly once
even if multiple cleanup paths race.  The helper functions below provide
those two mechanisms.

<<helper functions>>=
def make_tmux_channel(prefix: str) -> str:
    """Return a unique tmux wait-for channel name."""
    return (
        f"nytid-{prefix}-"
        f"{os.getpid()}-{time.time_ns()}"
    )


def make_tmux_completion_guard(
    status_file: Optional[str],
) -> Optional[str]:
    """Return the atomic completion guard path."""
    if status_file is None:
        return None
    return status_file + ".guard"


def build_tmux_completion_shell(
    *,
    status_file: Optional[str] = None,
    wait_channel: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
    completion_guard: Optional[str] = None,
    status_arg: str,
    signal_arg: str,
) -> str:
    """Return shell code for one-shot tmux completion."""
    shell_commands = []

    if status_file is not None:
        shell_commands.append(
            "printf 'status=%s\\nsignal=%s\\n' "
            f"{status_arg} {signal_arg} "
            f"> {shlex.quote(status_file)}"
        )
    if on_exit_shell is not None:
        shell_commands.append(on_exit_shell)
    if wait_channel is not None:
        shell_commands.append(
            "tmux wait-for -S " + shlex.quote(wait_channel)
        )

    body = "; ".join(shell_commands) or ":"
    if completion_guard is None:
        return body
    return (
        f"if mkdir {shlex.quote(completion_guard)} 2>/dev/null; then "
        f"{body}; "
        "fi"
    )


def build_tmux_wait_wrapper(
    command_args: List[str],
    ready_channel: str,
    *,
    status_file: Optional[str] = None,
    wait_channel: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
    completion_guard: Optional[str] = None,
) -> List[str]:
    """Return a wrapper that waits and records normal exit."""
    script_parts = [
        f"tmux wait-for {shlex.quote(ready_channel)} || exit $?",
        '"$@"',
        "status=$?",
    ]
    completion_shell = build_tmux_completion_shell(
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
        status_arg='"$status"',
        signal_arg="''",
    )
    if completion_shell != ":":
        script_parts.append(completion_shell)
    script_parts.append('exit "$status"')
    return [
        "/bin/sh",
        "-c",
        "; ".join(script_parts),
        "sh",
    ] + command_args


def build_tmux_hook_command(
    *,
    status_file: Optional[str] = None,
    wait_channel: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
    completion_guard: Optional[str] = None,
) -> str:
    """Build the tmux hook command for abnormal pane exit."""
    shell_command = build_tmux_completion_shell(
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
        status_arg=shlex.quote("#{pane_dead_status}"),
        signal_arg=shlex.quote("#{pane_dead_signal}"),
    )
    if shell_command == ":":
        return ""
    return "run-shell " + shlex.quote(shell_command)
@

When tmux splits a pane, the new pane inherits pane-scoped
options---including our exit hooks.  Without a guard, closing
\emph{any} descendant pane would stop tracking, even if the
original tracked pane is still alive.

The same inheritance bug affects [[new-window]]: creating a window
with \texttt{\^{}b c} while focused on the tracked pane causes the
new pane to inherit the exit hooks.  When that new window closes,
tmux has already selected a new active window (typically the tracked
one).  A format-string guard like [[#{==:#{pane_id},%42}]] fails
here because [[#{pane_id}]] resolves to the \emph{currently active}
pane---not the pane that triggered the event---so the guard
passes and tracking stops.

Instead of comparing pane IDs, we ask the semantically correct
question: is the tracked pane still alive?  We use
[[tmux display-message -t]] targeting the tracked pane; the command
fails (non-zero exit) when the pane no longer exists.  With the
leading~[[!]], the hook body only fires when the tracked pane is
dead.

This approach is correct across all exit paths:
\begin{description}
\item[Normal exit]  The wrapper script
  ([[build_tmux_wait_wrapper]]) runs the [[on_exit_shell]]
  \emph{before} the pane exits, so the wrapper handles cleanup.
  When the pane subsequently dies and the hook fires, the tracked
  pane is dead, so the guard lets the hook run---but
  [[_stop-detached]] uses [[quiet_if_missing]], making the
  duplicate invocation harmless.
\item[Abnormal exit]  When the pane is killed (e.g.\@ via
  [[kill-pane]]), the wrapper never executes its cleanup.  The
  [[pane-exited]]/[[pane-died]] hooks fire, the tracked pane is
  dead, and the guard lets the hook stop tracking.
\item[Spurious firing]  When a \emph{different} pane exits (via
  inheritance from [[split-window]] or the [[new-window]] bug),
  the tracked pane is still alive, so
  [[tmux display-message -t]] succeeds and the guard suppresses
  the hook.
\end{description}

For pane [[%42]] the resulting hook is:
\begin{quote}
\small [[if-shell '! tmux display-message -p -t %42 ""
  2>/dev/null' { run-shell '...' }]]
\end{quote}

<<helper functions>>=
def install_tmux_exit_hooks(
    pane_id: str,
    hook_command: str,
) -> None:
    """Install pane exit hooks for a newly created pane.

    The hook is wrapped in an ``if-shell`` guard that checks
    whether the tracked pane still exists, so that hooks
    inherited by split panes or (due to a tmux bug) by
    new-window panes are no-ops.
    """
    if not hook_command:
        return
    guarded_command = (
        "if-shell "
        f"'! tmux display-message -p -t {pane_id}"
        f' "" 2>/dev/null\' '
        f"{{ {hook_command} }}"
    )
    for hook_name in ("pane-exited", "pane-died"):
        subprocess.run(
            [
                "tmux",
                "set-hook",
                "-p",
                "-t",
                pane_id,
                hook_name,
                guarded_command,
            ],
            check=True,
        )


def parse_tmux_exit_status(text: str) -> int:
    """Parse tmux hook status text into a shell exit code."""
    data = {}
    for line in text.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        data[key] = value

    signal_str = data.get("signal", "")
    if signal_str:
        return 128 + int(signal_str)

    status_str = data.get("status", "")
    if status_str:
        return int(status_str)

    return 1


def read_tmux_exit_status(status_file: str) -> int:
    """Read the exit code recorded by the tmux hook."""
    try:
        with open(status_file) as f:
            return parse_tmux_exit_status(f.read())
    except OSError:
        return 1


def run_tmux_command(
    command_args: List[str],
    *,
    cwd: str,
    env: Dict[str, str],
    window: bool = False,
    window_name: Optional[str] = None,
    block: bool = True,
    exit_status_file: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
    focus_labels: Optional[List[str]] = None,
    focus_who: Optional[str] = None,
    focus_window: bool = False,
) -> Optional[int]:
    """Run a command in tmux and optionally wait for exit.

    When ``focus_labels`` is set, auto-suspend hooks are
    installed.  Pane launches use pane-focus hooks, while
    window launches use tmux's selected-window state.
    """
    ready_channel = make_tmux_channel("ready")
    wait_channel = None
    status_file = exit_status_file
    pane_id = None
    window_id = None
    session_id = None
    remove_status_file = False
    completion_guard = None

    if block and status_file is None:
        fd, status_file = tempfile.mkstemp(
            prefix="nytid-tmux-",
            suffix=".status",
        )
        os.close(fd)
        remove_status_file = True
    if block:
        wait_channel = make_tmux_channel("done")
        completion_guard = make_tmux_completion_guard(
            status_file
        )

    wrapped_command = build_tmux_wait_wrapper(
        command_args,
        ready_channel,
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
    )

    hook_command = build_tmux_hook_command(
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
    )

    tmux_args = [
        "tmux",
        "new-window" if window else "split-window",
        "-P",
        "-F",
        "#{pane_id} #{window_id} #{session_id}",
    ]
    for key, value in sorted(env.items()):
        tmux_args.extend([
            "-e",
            f"{key}={value}",
        ])
    if window and window_name:
        tmux_args.extend(["-n", window_name])
    tmux_args.extend([
        "-c",
        cwd,
    ])
    tmux_args.append(shlex.join(wrapped_command))

    old_sigint = None
    if block:
        old_sigint = signal.signal(
            signal.SIGINT, signal.SIG_IGN
        )

    try:
        result = subprocess.run(
            tmux_args,
            check=True,
            capture_output=True,
            text=True,
        )
        pane_info = result.stdout.strip().split()
        if pane_info:
            pane_id = pane_info[0]
        if len(pane_info) > 1:
            window_id = pane_info[1]
        if len(pane_info) > 2:
            session_id = pane_info[2]
        install_tmux_exit_hooks(pane_id, hook_command)
        if focus_labels and focus_who:
            if focus_window and window_id and session_id:
                write_window_labels(
                    window_id, focus_who, focus_labels,
                )
                install_tmux_window_sync_hooks(session_id)
                install_tmux_window_cleanup_hook(
                    pane_id,
                    window_id,
                    focus_who,
                )
            else:
                write_pane_labels(
                    pane_id, focus_who, focus_labels,
                )
                install_tmux_focus_hooks(
                    pane_id, focus_who,
                )
                install_tmux_suspend_cleanup_hook(
                    pane_id, focus_who,
                )
        subprocess.run(
            ["tmux", "wait-for", "-S", ready_channel],
            check=True,
        )
        if not block:
            return None
        subprocess.run(
            ["tmux", "wait-for", wait_channel],
            check=True,
        )
        return read_tmux_exit_status(status_file)
    except Exception:
        if pane_id:
            try:
                subprocess.run(
                    ["tmux", "kill-pane", "-t", pane_id],
                    check=False,
                )
            except OSError:
                pass
        raise
    finally:
        if block and old_sigint is not None:
            signal.signal(signal.SIGINT, old_sigint)
        if remove_status_file and status_file is not None:
            try:
                os.unlink(status_file)
            except OSError:
                pass
        if completion_guard is not None:
            try:
                os.rmdir(completion_guard)
            except OSError:
                pass
@

When [[--no-block]] is used, the tmux pane needs to call
[[nytid track stop]] after the child exits.  The
[[build_detached_track_finalize_command]] helper (defined in
\cref{track:auto-suspend}) constructs the appropriate shell command.

<<argument and option definitions>>=
detached_labels_arg = typer.Argument(...)
@

\subsection{Auto-Suspend on Focus Change}
\label{track:auto-suspend}

When a tmux pane running a tracked shell loses focus, the user has
switched their attention elsewhere.  Continuing to accumulate time
against those labels is inaccurate.  Auto-suspend solves this by
hooking into tmux's [[pane-focus-out]] and [[pane-focus-in]] events.

On focus-out, we snapshot which of the pane's labels are still active
(the user may have stopped some manually), stop those labels, and
record the snapshot in a per-pane state file.  On focus-in, we read
that state file, restart the saved labels, and delete the file.
If the state file is missing on focus-in (because the pane was
stopped entirely while unfocused), the resume is a silent no-op.

Each focus-out/focus-in cycle produces completed [[TrackingEntry]]
records---many small entries rather than one long one.  This is the
correct representation: the entries reflect attended time.

Note that [[pane-focus-out]] fires not only when the user switches to
another tmux pane or window, but also when the terminal emulator itself
loses focus---for example, when the user Alt-Tabs to a web browser.
Pane-based auto-suspend therefore treats \emph{any} departure from the
terminal as an interruption.  For workflows where switching between the
terminal and a browser is routine (looking up documentation, checking a
web application), this behaviour is too aggressive.  The [[--window]]
launch mode avoids the problem: it tracks which tmux window is selected
rather than terminal focus, so Alt-Tabbing to a browser does not suspend
tracking (see \cref{track:window-auto-suspend}).

\subsubsection{Suspend State Files}

Each tracked pane that uses auto-suspend stores a JSON file
identifying the labels that were suspended.  The filename encodes
the tmux pane ID (with the leading [[%]] replaced by [[pane_]])
and the worker identity so that parallel workers in different panes
do not collide.

<<helper functions>>=
def suspend_state_path(
    pane_id: str, who: str
) -> pathlib.Path:
    """Return the path to a pane's suspend state file.

    The file records which labels were suspended
    when the pane lost focus.
    """
    safe_pane = pane_id.replace("%", "pane_")
    return (
        get_tracking_dir()
        / f"suspend_{safe_pane}_{sanitize_who(who)}.json"
    )
@

Writing the state file must be atomic: a half-written file would
confuse the resume path.  We write to a temporary file in the same
directory and rename, which is atomic on POSIX filesystems.

<<helper functions>>=
def write_suspend_state(
    path: pathlib.Path, labels: List[str]
) -> None:
    """Atomically write suspended labels to a state file."""
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(".tmp")
    tmp.write_text(json.dumps(labels))
    tmp.rename(path)
@

Reading the state file returns [[None]] when the file is missing or
corrupt.  This lets the resume path treat absence as a no-op rather
than raising, which is the normal case when a pane exits while
unfocused (the cleanup hook already removed the file).

<<helper functions>>=
def read_suspend_state(
    path: pathlib.Path,
) -> Optional[List[str]]:
    """Read suspended labels, or ``None`` if missing."""
    try:
        return json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return None
@

Deletion is idempotent: the file may already have been removed by
the cleanup hook or by a concurrent resume in another pane.

<<helper functions>>=
def delete_suspend_state(
    path: pathlib.Path,
) -> None:
    """Remove a suspend state file if it exists."""
    try:
        path.unlink()
    except OSError:
        pass
@

\subsubsection{Per-Pane Active Labels}

The suspend state file records which labels were suspended during a
single focus-out event, but it does not track which labels
\emph{belong} to a pane.  When focus hooks are installed, the label
list is embedded directly in the hook command---so labels started
later in the same pane are invisible to auto-suspend.

To fix this, we maintain a per-pane \emph{active labels file} that
the suspend hook reads dynamically.  Both [[track start]] and
[[track stop]] update this file when they detect they are running
inside a tracked pane (via the [[TMUX_PANE]] environment variable).
The file exists only for panes launched with auto-suspend; a plain
[[track start]] in an untracked pane creates no file.

The naming convention mirrors [[suspend_state_path]]: the tmux pane
ID's leading [[%]] becomes [[pane_]], and the worker identity is
appended.

<<helper functions>>=
def pane_labels_path(
    pane_id: str, who: str
) -> pathlib.Path:
    """Return path to a pane's active labels file.

    The file records which labels should be
    suspended when the pane loses focus.
    """
    safe_pane = pane_id.replace("%", "pane_")
    return (
        get_tracking_dir()
        / f"pane_labels_{safe_pane}"
        f"_{sanitize_who(who)}.json"
    )
@

Reading returns [[None]] when the file is absent, which lets callers
distinguish \enquote{no file} (pane is not tracked) from
\enquote{empty list} (all labels removed).

<<helper functions>>=
def read_pane_labels(
    pane_id: str, who: str,
) -> Optional[List[str]]:
    """Read pane labels, or ``None`` if not tracked."""
    path = pane_labels_path(pane_id, who)
    try:
        return json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return None
@

Writing uses the same atomic tmp-then-rename strategy as the suspend
state helpers.

<<helper functions>>=
def write_pane_labels(
    pane_id: str, who: str,
    labels: List[str],
) -> None:
    """Atomically write the pane's active labels."""
    path = pane_labels_path(pane_id, who)
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(".tmp")
    tmp.write_text(json.dumps(labels))
    tmp.rename(path)
@

When [[track start]] adds labels to an already-tracked pane, the new
labels must merge into the existing set.  Order is preserved so that
the suspend hook processes labels in the same sequence they were
started---keeping the suspend state file predictable across cycles.
Duplicates are skipped because a user may restart a label that is
already registered.

<<helper functions>>=
def add_pane_labels(
    pane_id: str, who: str,
    labels: List[str],
) -> None:
    """Add labels to the pane's active set."""
    existing = read_pane_labels(pane_id, who) or []
    seen = set(existing)
    merged = list(existing)
    for lbl in labels:
        if lbl not in seen:
            merged.append(lbl)
            seen.add(lbl)
    write_pane_labels(pane_id, who, merged)
@

When [[track stop]] removes labels from a tracked pane, the file
must shrink accordingly so the next focus-out does not try to suspend
already-stopped labels.  Deleting the file when empty (rather than
writing~[[]]) ensures the pane reverts to the \enquote{untracked}
state---matching the invariant that file existence means
\enquote{auto-suspend is active.}

<<helper functions>>=
def remove_pane_labels(
    pane_id: str, who: str,
    labels: List[str],
) -> None:
    """Remove labels from the pane's active set."""
    existing = read_pane_labels(pane_id, who)
    if existing is None:
        return
    to_remove = set(labels)
    remaining = [
        lbl for lbl in existing
        if lbl not in to_remove
    ]
    if remaining:
        write_pane_labels(pane_id, who, remaining)
    else:
        delete_pane_labels(pane_id, who)
@

Deletion is idempotent, matching [[delete_suspend_state]].

<<helper functions>>=
def delete_pane_labels(
    pane_id: str, who: str,
) -> None:
    """Remove a pane's active labels file."""
    try:
        pane_labels_path(pane_id, who).unlink()
    except OSError:
        pass
@

Pane and window label files are updated together whenever interactive tracking
starts or stops labels.  Centralising that policy in helper functions keeps
call sites from forgetting the tmux bookkeeping.  The pane side remains guarded
by [[read_pane_labels()]] returning non-[[None]]: only panes launched with
auto-suspend should gain a pane labels file.  Window tracking is intentionally
asymmetric.  Removing [[devel]] from window~A should stop that window from
reviving it later, but another tracked window~B may still declare [[devel]]
independently.

<<helper functions>>=
def register_tmux_context_labels(
    labels: List[str], who: str,
) -> None:
    """Add labels to the current pane/window tracking context."""
    pane_id = os.environ.get("TMUX_PANE")
    if pane_id:
        if read_pane_labels(pane_id, who) is not None:
            add_pane_labels(
                pane_id, who, list(labels),
            )
    window_id = get_current_tracked_window_id(who)
    if window_id:
        add_window_labels(
            window_id, who, list(labels),
        )


def unregister_tmux_context_labels(
    labels: List[str], who: str,
) -> None:
    """Remove labels from the current pane/window tracking context."""
    pane_id = os.environ.get("TMUX_PANE")
    if pane_id:
        if read_pane_labels(pane_id, who) is not None:
            remove_pane_labels(
                pane_id, who, list(labels),
            )
    window_id = get_current_tracked_window_id(who)
    if window_id:
        remove_window_labels(
            window_id, who, list(labels),
        )
