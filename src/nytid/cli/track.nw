    )

    with caplog.at_level(logging.WARNING):
        merged, duplicate_count = normalize_tracking_entries([entry, entry])

    assert len(merged) == 1
    assert duplicate_count == 1
    assert "Merged 1 duplicate tracking entry" in caplog.text
@

\subsection{Listing Tracked Sessions}

The [[ls]] command fills a gap between [[status]] (which shows only the
\emph{currently active} session) and [[stats]] (which shows
\emph{aggregated} totals).  Sometimes you just want to see the last few
individual entries --- for example, to verify that yesterday's grading
session was recorded, or to eyeball recent work before writing a
timesheet.  The [[ls]] command provides this quick, per-entry view.

Unlike [[stats]], which defaults to a 1-day time window, [[ls]] uses a
count limit ([[-n]]) instead.  A time window would hide old entries even
when the user explicitly asks \enquote{show me my last 20 sessions}.
The count-based approach always returns exactly as many entries as
requested (or fewer if the history is shorter).

When the user wants to repair history, though, a bare timestamp line is
not enough: they need a stable way to name one specific entry.  The
optional [[--id]] flag prepends a short, unique prefix of each entry's
[[content_hash()]], giving us Git-style identification without storing a
separate persistent identifier.

<<ls command>>=
@cli.command(name="ls")
def ls_entries(
    labels: List[str] = typer.Argument(
        None,
        help="Filter by labels "
             "(shows all if not specified)",
        autocompletion=complete_historical_labels),
    n: int = typer.Option(
        10, "--number", "-n",
        help="Number of entries to show"),
    show_id: bool = typer.Option(
        False, "--id",
        help="Show unique content-hash prefixes for entries"),
    who: Optional[str] = typer.Option(
        None, "--who", "-w",
        help="Filter by worker "
             "(shows all if omitted)",
        autocompletion=complete_workers),
):
    """
    List recent completed tracking entries.

    Use this to review the last few sessions, filter by course or worker, or
    show short IDs before editing or removing an entry.

    \b
    Examples:
      nytid track ls
      nytid track ls DD1310 -n 5
      nytid track ls --id
      nytid track ls --who Dan-Claude
    """
    <<load and filter for ls>>
    <<display ls entries>>
@

We use the shared [[filter_entries]] helper but skip the time-window
filter --- the count limit ([[-n]]) controls how many entries appear
instead:

<<load and filter for ls>>=
entries = filter_entries(who=who, labels=labels)
if not entries:
    typer.echo("No tracking data available.")
    return
@

Entries are sorted most-recent-first because the typical use case is
checking recent work --- older entries scroll off the terminal rather
than consuming attention.  The format is deliberately plain text (not a
Rich table) to stay consistent with [[status]] and [[stats]], and to
remain pipeable to tools like [[grep]] or [[awk]]:

<<display ls entries>>=
entries.sort(
    key=lambda e: e.start_time, reverse=True
)
hash_prefixes = abbreviate_hashes(
    [entry.content_hash() for entry in entries]
)
for entry in entries[:n]:
    ts = entry.start_time.strftime("%Y-%m-%d %H:%M")
    dur = format_duration(entry.duration())
    lbl = get_labels_display(entry.labels)
    parts = [f"{ts}  {dur}  {lbl}"]
    if show_id:
        parts.insert(0, hash_prefixes[entry.content_hash()])
    parts.append(f"[{entry.who}]")
    if entry.description:
        parts.append(f"- {entry.description}")
    typer.echo("  ".join(parts))
@

The same hash prefixes become the entry point for precise history
inspection and repair.  [[show]] prints one historical entry in full,
[[edit]] replaces one entry with updated content, and [[rm]] removes one
entry after confirmation.  All three resolve a hash prefix against the
current history so unrelated additions do not shift the user's target.

<<history entry helpers>>=
def parse_edit_tracking_start_time(
    at: Optional[str],
    original: TrackingEntry,
) -> datetime.datetime:
    """Return the edited start time for a historical entry."""
    if at is None:
        return original.start_time
    return parse_at_time(at, reference_time=original.start_time)

def parse_edit_tracking_end_time(
    end_at: Optional[str],
    duration_minutes: Optional[int],
    start_time: datetime.datetime,
    original: TrackingEntry,
) -> datetime.datetime:
    """Return the edited end time for a historical entry."""
    if end_at is not None and duration_minutes is not None:
        raise ValueError("Cannot use both --end-at and --duration")
    if end_at is not None:
        return parse_at_time(end_at, reference_time=original.end_time)
    if duration_minutes is not None:
        if duration_minutes <= 0:
            raise ValueError("Duration must be positive")
        return start_time + datetime.timedelta(minutes=duration_minutes)
    return original.end_time

def render_tracking_entry(entry: TrackingEntry) -> List[str]:
    """Render one historical entry for human inspection."""
    return [
        f"ID: {entry.content_hash()}",
        f"Start: {entry.start_time.isoformat(sep=' ')}",
        f"End: {entry.end_time.isoformat(sep=' ')}",
        f"Duration: {format_duration(entry.duration())}",
        f"Labels: {get_labels_display(entry.labels)}",
        f"Who: {entry.who}",
        f"Description: {entry.description}" if entry.description else "Description:",
    ]

<<show command>>=
@cli.command()
def show(
    entry_hash: str = typer.Argument(..., help="Tracking entry hash prefix"),
):
    """
    Show one historical tracking entry in full detail.

    Use this after `track ls --id` when you want to inspect timestamps,
    labels, worker, and description before editing or removing an entry.

    \b
    Example:
      nytid track show a1b2c3
    """
    entries = load_tracking_data()
    if not entries:
        typer.echo("No tracking data available.", err=True)
        raise typer.Exit(1)

    try:
        entry = resolve_tracking_entry(entries, entry_hash)
    except ValueError as exc:
        typer.echo(f"Error: {exc}", err=True)
        raise typer.Exit(1)

    for line in render_tracking_entry(entry):
        typer.echo(line)
@

<<edit command>>=
@cli.command()
def edit(
    entry_hash: str = typer.Argument(..., help="Tracking entry hash prefix"),
    at: Optional[str] = typer.Option(
        None, "--at",
        help="Set start time (e.g. '14:30' or '2024-12-13 14:30')"),
    end_at: Optional[str] = typer.Option(
        None, "--end-at",
        help="Set end time (e.g. '15:45' or '2024-12-13 15:45')"),
    duration_minutes: Optional[int] = typer.Option(
        None, "--duration", "-d",
        help="Set duration in minutes"),
    label: Optional[List[str]] = typer.Option(
        None, "--label", "-l",
        help="Replace all labels",
        autocompletion=complete_historical_labels),
    description: Optional[str] = typer.Option(
        None, "--description",
        help="Replace the description"),
    who: Optional[str] = typer.Option(
        None, "--who", "-w",
        help="Replace the worker identity",
        autocompletion=complete_workers),
):
    """
    Edit one historical tracking entry.

    Use this to fix labels, description, worker, or timestamps after noticing a
    mistake in recorded history.

    \b
    Examples:
      nytid track edit a1b2c3 --description "Weekly planning meeting"
      nytid track edit a1b2c3 --at 14:00 --end-at 15:30
      nytid track edit a1b2c3 -l DD1310 -l grading
    """
    def update_history(entries):
        if not entries:
            raise ValueError("No tracking data available")

        original = resolve_tracking_entry(entries, entry_hash)
        start_time = parse_edit_tracking_start_time(at, original)
        end_time = parse_edit_tracking_end_time(
            end_at,
            duration_minutes,
            start_time,
            original,
        )
        if end_time <= start_time:
            raise ValueError("End time must be after start time")

        updated = TrackingEntry(
            start_time=start_time,
            end_time=end_time,
            labels=(label if label is not None else original.labels),
            description=(
                description if description is not None
                else original.description
            ),
            who=(who if who is not None else original.who),
        )
        updated_entries = replace_tracking_entry(entries, original, updated)
        return updated_entries, original, updated

    try:
        _, original, updated = mutate_tracking_history(update_history)
    except ValueError as exc:
        typer.echo(f"Error: {exc}", err=True)
        raise typer.Exit(1)

    typer.echo(
        f"Updated {original.content_hash()[:TRACKING_HASH_PREFIX_MIN_LENGTH]} -> "
        f"{updated.content_hash()[:TRACKING_HASH_PREFIX_MIN_LENGTH]}"
    )
@

<<remove command>>=
@cli.command(name="rm")
def rm(
    entry_hash: str = typer.Argument(..., help="Tracking entry hash prefix"),
    force: bool = typer.Option(
        False, "--force", "-f",
        help="Skip confirmation"),
):
    """
    Remove one historical tracking entry.

    Use this when a session was recorded by mistake and should disappear rather
    than be repaired in place.

    \b
    Examples:
      nytid track rm a1b2c3
      nytid track rm a1b2c3 --force
    """
    entries = load_tracking_data()
    if not entries:
        typer.echo("No tracking data available.", err=True)
        raise typer.Exit(1)

    try:
        target = resolve_tracking_entry(entries, entry_hash)
    except ValueError as exc:
        typer.echo(f"Error: {exc}", err=True)
        raise typer.Exit(1)

    if not force and not typer.confirm(
        f"Remove tracking entry {target.content_hash()[:TRACKING_HASH_PREFIX_MIN_LENGTH]}?"
    ):
        typer.echo("Cancelled.")
        raise typer.Exit(0)

    def update_history(current_entries):
        current_target = resolve_tracking_entry(
            current_entries,
            target.content_hash(),
        )
        updated_entries = remove_tracking_entry(current_entries, current_target)
        return updated_entries, current_target

    try:
        _, removed = mutate_tracking_history(update_history)
    except ValueError as exc:
        typer.echo(f"Error: {exc}", err=True)
        raise typer.Exit(1)

    typer.echo(
        f"Removed {removed.content_hash()[:TRACKING_HASH_PREFIX_MIN_LENGTH]}: "
        f"{get_labels_display(removed.labels)}"
    )
@

The basic case confirms that labels and duration appear in the output
--- if the command ran but produced no recognisable content, the
user would have no way to tell whether their session was recorded:

<<test functions>>=
def test_ls_default(temp_tracking_dir):
    """Test ls shows recent entries."""
    runner.invoke(cli, [
        "add", "DD1310", "grading",
        "--duration", "60",
        "--description", "Graded homework"
    ])
    runner.invoke(cli, [
        "add", "DD1310", "lecture",
        "--duration", "45"
    ])
    result = runner.invoke(cli, ["ls"])
    assert result.exit_code == 0
    assert "DD1310" in result.output
    assert "grading" in result.output or \
        "lecture" in result.output

def test_ls_show_id_includes_hash_prefix(temp_tracking_dir):
    """--id prepends a unique digest prefix to each row."""
    runner.invoke(cli, [
        "add", "DD1310",
        "--duration", "60",
        "--at", "2026-03-12 10:00"
    ])

    result = runner.invoke(cli, ["ls", "--id", "-n", "1"])

    assert result.exit_code == 0
    first_field = result.stdout.strip().split()[0]
    assert len(first_field) >= TRACKING_HASH_PREFIX_MIN_LENGTH

def test_show_tracking_entry_by_hash(temp_tracking_dir):
    """show prints the selected historical entry."""
    runner.invoke(cli, [
        "add", "meeting",
        "--duration", "30",
        "--at", "2026-03-12 10:00",
        "--description", "Discuss roadmap"
    ])
    entry = load_tracking_data()[0]

    result = runner.invoke(cli, ["show", entry.content_hash()[:8]])

    assert result.exit_code == 0
    assert entry.content_hash() in result.stdout
    assert "Discuss roadmap" in result.stdout

def test_edit_tracking_entry_by_hash(temp_tracking_dir):
    """edit replaces one historical entry and prints the new hash."""
    runner.invoke(cli, [
        "add", "nytid", "work",
        "--duration", "90",
        "--at", "2026-03-12 10:00"
    ])
    original = load_tracking_data()[0]

    result = runner.invoke(cli, [
        "edit", original.content_hash()[:8],
        "--duration", "30",
        "--description", "Trimmed session"
    ])

    assert result.exit_code == 0
    entries = load_tracking_data()
    assert len(entries) == 1
    assert entries[0].duration() == datetime.timedelta(minutes=30)
    assert entries[0].description == "Trimmed session"
    assert entries[0].content_hash()[:TRACKING_HASH_PREFIX_MIN_LENGTH] in result.stdout

def test_edit_tracking_entry_rejects_invalid_interval(temp_tracking_dir):
    """edit rejects end times before the start."""
    runner.invoke(cli, [
        "add", "nytid",
        "--duration", "60",
        "--at", "2026-03-12 10:00"
