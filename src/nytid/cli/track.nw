<<detached suspend command>>=
@cli.command(
    name="_suspend-detached", hidden=True
)
def suspend_detached(
    pane_id: Annotated[str, pane_id_opt],
    tmux_server_key: Annotated[str, tmux_server_key_opt],
    who: Annotated[str, who_opt] = default_username,
):
    """Suspend labels when a tracked pane loses focus."""
    labels = with_tmux_context_lock(
        lambda: read_pane_labels(
            pane_id, who, tmux_server_key,
        )
    )
    if not labels:
        return
    suspend_tracking_labels(
        who=who,
        labels=labels,
        pane_id=pane_id,
        tmux_server_key=tmux_server_key,
    )
