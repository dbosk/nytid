def test_parse_tmux_socket_path_reads_socket_path():
    """$TMUX parsing keeps commas that belong to the socket path."""
    assert parse_tmux_socket_path("/tmp/tmux.sock,123,0") == \
        "/tmp/tmux.sock"
    assert parse_tmux_socket_path("/tmp/tmux,sock,123,0") == \
