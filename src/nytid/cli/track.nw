        f"action: execute-switch\n"
        f"target: {'tracked' if switch_target_tracked else 'untracked'}\n"
        f"source: {switch_source_tracked}\n"
        f"stop: {' '.join(last_stop_labels) or '(none)'}\n"
        f"start: {' '.join(last_start_labels) or '(none)'}\n"
