    """edit rejects end times before the start."""
    runner.invoke(cli, [
        "add", "nytid",
        "--duration", "1",
        "--at", "2026-03-12 10:00"
    ])
    entry = load_tracking_data()[0]

    result = runner.invoke(cli, [
        "edit", entry.content_hash()[:8],
        "--end-at", "2026-03-12 09:00"
    ])

    assert result.exit_code == 1
    assert "End time must be after start time" in result.stdout

def test_rm_tracking_entry_by_hash(temp_tracking_dir):
    """rm removes one historical entry by hash."""
    runner.invoke(cli, [
        "add", "nytid",
        "--duration", "1",
        "--at", "2026-03-12 10:00"
    ])
    entry = load_tracking_data()[0]

    result = runner.invoke(cli, [
        "rm", entry.content_hash()[:8],
        "--force"
    ])

    assert result.exit_code == 0
    assert load_tracking_data() == []

def test_rm_tracking_entry_requires_confirmation(temp_tracking_dir):
    """rm asks for confirmation unless --force is given."""
    runner.invoke(cli, [
        "add", "nytid",
        "--duration", "1",
        "--at", "2026-03-12 10:00"
    ])
    entry = load_tracking_data()[0]

    result = runner.invoke(
        cli,
        ["rm", entry.content_hash()[:8]],
        input="n\n",
    )

    assert result.exit_code == 0
    assert "Cancelled." in result.stdout
    assert len(load_tracking_data()) == 1
@

The [[-n]] limit is the primary output-size control; if the slice
[[entries[:n]]] were missing or the argument ignored, the command
would always dump the full history regardless of what the user asked:

<<test functions>>=
def test_ls_limit(temp_tracking_dir):
    """Test -n flag limits output."""
    for i in range(5):
        runner.invoke(cli, [
            "add", f"label{i}",
            "--duration", "30m"
        ])
    result = runner.invoke(cli, ["ls", "-n", "2"])
    assert result.exit_code == 0
    lines = [
        line for line in result.output.strip().splitlines()
        if line.strip()
    ]
    assert len(lines) == 2
