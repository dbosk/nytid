    window_id = get_current_tracked_window_id(
        who, tmux_server_key,
    )
    if window_id:
        remove_window_labels(
            window_id, who, tmux_server_key,
            list(labels),
        )


def unregister_tmux_context_labels(
    labels: List[str], who: str,
) -> None:
    """Remove labels from the current pane/window tracking context."""
    with_tmux_context_lock(
        lambda: _unregister_tmux_context_labels_unlocked(
