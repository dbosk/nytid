def test_event_buffer_locking(
    temp_tracking_dir,
):
    """Simultaneous appends serialize through the file lock."""
    import threading

    who = "me"
    barrier = threading.Barrier(4)
    calls = []
    stop_event = build_window_event_line(
        "stop", ["work"],
        datetime.datetime(2026, 2, 20, 10, 0),
        window_id="@1",
    )
    start_event = build_window_event_line(
        "start", ["admin"],
        datetime.datetime(2026, 2, 20, 10, 1),
        window_id="@2",
    )

    def record_stop(**kwargs):
        calls.append(("stop", kwargs["labels"]))

    def record_start(**kwargs):
        calls.append(("start", kwargs["labels"]))

    def worker(event_line):
        barrier.wait()
        append_and_check_window_event(
            who, TEST_SERVER_KEY, TEST_SESSION_ID,
            event_line,
        )

    with patch(
        "nytid.cli.track.stop_tracking_labels",
        side_effect=record_stop,
    ), patch(
        "nytid.cli.track.start_tracking_labels",
        side_effect=record_start,
    ):
        threads = [
            threading.Thread(target=worker, args=(stop_event,)),
            threading.Thread(target=worker, args=(start_event,)),
            threading.Thread(
                target=worker,
                args=(
                    build_window_switch_event_line(
                        target_tracked=True,
                        source_tracked=True,
                        source_window_id="@1",
                        target_window_id="@2",
                    ),
                ),
            ),
        ]
        for thread in threads:
            thread.start()
        barrier.wait()
        for thread in threads:
            thread.join()

    assert sorted(calls) == [
        ("start", ["admin"]),
        ("stop", ["work"]),
    ]
    assert window_event_buffer_path(
        who, TEST_SERVER_KEY, TEST_SESSION_ID,
    ).read_text() == ""

