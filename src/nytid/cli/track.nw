    runner.invoke(cli, ["switch", "grading"])
    result = runner.invoke(cli, ["switch"])
    assert result.exit_code == 0
    assert "Switched back to:" in result.stdout
    session = load_active_session()
    active = session.get_active_labels()
    assert "DD1310" in active or "lecture" in active
    assert "grading" not in active
    # grading is now the saved set ready for another toggle
    assert session.switch_other is not None

def test_switch_matches_stop_start_timing(temp_tracking_dir):
    """Switch back starts the restored labels at the switch time."""
    runner.invoke(cli, ["start", "A", "--at", "2026-03-16 15:00"])
    runner.invoke(cli, ["switch", "B", "--at", "2026-03-16 15:10"])
    result = runner.invoke(cli, ["switch", "--at", "2026-03-16 15:15"])

    assert result.exit_code == 0

    entries = sorted(
        load_tracking_data(),
        key=lambda entry: entry.start_time,
    )
    assert len(entries) == 2
    assert entries[0].labels == ["A"]
    assert entries[0].start_time == datetime.datetime(2026, 3, 16, 15, 0)
    assert entries[0].end_time == datetime.datetime(2026, 3, 16, 15, 10)
