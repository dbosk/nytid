Todo and track both describe shell context as a namespace plus the values
that identify the current work.  The same rendered string appears in
[[PS1]] and, for tmux windows, in the window name.  We therefore build
that context string once and let both commands reuse it.

<<helper functions>>=
def join_context_values(values: List[str]) -> str:
    """Return context values joined for prompts and tmux names."""
    return " ".join(values)


def build_context_name(
    prefix: str,
    values: List[str],
) -> str:
    """Return a prefixed context label for prompts and tmux names."""
    value_text = join_context_values(values)
    if value_text:
        return f"{prefix}:{value_text}"
    return prefix


def apply_context_prompt(
    context_name: str,
    env: Dict[str, str],
) -> None:
    """Store a context marker in [[env]] for child shells."""
    if "PS1" in env:
        env["PS1"] = f"{context_name} {env['PS1']}"
    else:
        env["PS1"] = f"{context_name} \\w\\n$ "
