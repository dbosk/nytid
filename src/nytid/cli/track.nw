\paragraph{Suspend and resume cycle.}
We test that suspending an active session writes the correct
state file and stops the labels, and that resuming restarts them.

<<test functions>>=
def test_suspend_resume_cycle(temp_tracking_dir):
    """Suspend stops active labels, resume restarts them."""
    runner.invoke(cli, [
        "start", "work", "email",
    ])

    pane_id = "%99"
    suspend_tracking_labels(
        who=default_username,
        labels=["work", "email"],
        pane_id=pane_id,
        tmux_server_key=TEST_SERVER_KEY,
    )

    # Labels should be stopped
    session = load_active_session(default_username)
    assert session.get_active_labels() == []

    # State file should exist
    state_path = suspend_state_path(
        pane_id, default_username, TEST_SERVER_KEY,
    )
    labels = read_suspend_state(state_path)
    assert sorted(labels) == ["email", "work"]

    # Resume should restart them
    resume_tracking_labels(
        who=default_username,
        pane_id=pane_id,
        tmux_server_key=TEST_SERVER_KEY,
    )
    session = load_active_session(default_username)
    assert sorted(session.get_active_labels()) == [
        "email", "work",
    ]
    # State file should be cleaned up
    assert read_suspend_state(state_path) is None

    # Clean up
    runner.invoke(cli, ["stop"])

