<<constants>>=
AUTO_SUSPEND_CONFIG = "track.auto-suspend"
@


<<configuration management>>=
def should_auto_suspend(
    who: str,
    flag: Optional[bool],
) -> bool:
    """Resolve whether auto-suspend is enabled.

    Checks, in order: CLI flag, per-worker config,
    global config, hard-coded default (``True``).
    """
    if flag is not None:
        return flag
    worker_key = (
        f"{AUTO_SUSPEND_CONFIG}"
        f".{sanitize_who(who)}"
    )
    try:
        value = config.get(worker_key)
        return str(value).lower() in (
            "true", "1", "yes",
        )
    except KeyError:
        pass
    try:
        value = config.get(
            f"{AUTO_SUSPEND_CONFIG}.default"
        )
        return str(value).lower() in (
            "true", "1", "yes",
        )
    except KeyError:
        return True
@

