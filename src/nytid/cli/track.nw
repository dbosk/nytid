def test_build_tmux_wait_wrapper_signals_done_once():
    """Wrapper records normal exit and wakes waiters."""
    status_file = "/tmp/nytid.status"
    guard = make_tmux_completion_guard(status_file)

    wrapper = build_tmux_wait_wrapper(
        ["python", "-V"],
        "ready-chan",
        status_file=status_file,
        wait_channel="done-chan",
        on_exit_shell="cleanup-command",
        completion_guard=guard,
    )

    assert wrapper[:3] == ["/bin/sh", "-c", wrapper[2]]
    assert "tmux wait-for ready-chan" in wrapper[2]
    assert "status=$?" in wrapper[2]
    assert "mkdir /tmp/nytid.status.guard" in wrapper[2]
    assert "printf 'status=%s\\nsignal=%s\\n' \"$status\" ''" in (
        wrapper[2]
    )
    assert "cleanup-command" in wrapper[2]
    assert "tmux wait-for -S done-chan" in wrapper[2]
    assert wrapper[3:] == ["sh", "python", "-V"]


def test_build_tmux_hook_command_uses_guarded_run_shell():
    """Pane exit hooks become a guarded fallback path."""
    hook = build_tmux_hook_command(
        status_file="/tmp/nytid.status",
        wait_channel="done-chan",
        on_exit_shell="cleanup-command",
        completion_guard="/tmp/nytid.status.guard",
    )

    assert hook.startswith("run-shell ")
    assert "mkdir /tmp/nytid.status.guard" in hook
    assert "#{pane_dead_status}" in hook
    assert "#{pane_dead_signal}" in hook
    assert "cleanup-command" in hook
    assert "tmux wait-for -S done-chan" in hook

def test_install_tmux_exit_hooks_guards_pane_id():
    """Hooks use pane-existence guard to prevent
    inherited hooks from firing while tracked pane
    is alive."""
    with patch("subprocess.run") as mock_run:
        hook_cmd = "run-shell 'echo done'"
        install_tmux_exit_hooks("%42", hook_cmd)
        assert mock_run.call_count == 2
        for call in mock_run.call_args_list:
            cmd = call[0][0]
            hook_value = cmd[-1]
            assert "if-shell" in hook_value
            assert "display-message" in hook_value
            assert "%42" in hook_value
            assert hook_cmd in hook_value

def test_tracking_entry_with_who():
    """Test TrackingEntry serialization with who field"""
    start = datetime.datetime(2023, 1, 1, 10, 0, 0)
    end = datetime.datetime(2023, 1, 1, 11, 0, 0)
    entry = TrackingEntry(
        start, end, ["DD1310"], "test",
        who="Dan-Claude"
    )

    assert entry.who == "Dan-Claude"
    data = entry.to_dict()
    assert data["who"] == "Dan-Claude"

    # Round-trip
    entry2 = TrackingEntry.from_dict(data)
    assert entry2.who == "Dan-Claude"

def test_tracking_entry_backward_compat():
    """Test that old entries without who default to 'me'"""
    data = {
        "start_time": "2023-01-01T10:00:00",
        "end_time": "2023-01-01T11:00:00",
        "labels": ["DD1310"],
        "description": "old entry"
    }
    entry = TrackingEntry.from_dict(data)
    assert entry.who == "me"

def test_per_worker_session_files(temp_tracking_dir):
    """Test that two workers get independent session files"""
    # Start tracking for default worker
    runner.invoke(cli, ["start", "DD1310"])
    # Start tracking for Dan-Claude
    runner.invoke(cli, [
        "start", "coding", "--who", "Dan-Claude"
    ])

    # Verify both session files exist
    suffix = sanitize_who(default_username)
    me_file = (
        temp_tracking_dir
        / f"current_session_{suffix}.json"
    )
    dc_file = temp_tracking_dir / "current_session_dan-claude.json"
    assert me_file.exists()
    assert dc_file.exists()

def test_start_stop_with_who(temp_tracking_dir):
    """Test --who creates separate session"""
    result = runner.invoke(cli, [
        "start", "coding", "--who", "Dan-Claude"
    ])
    assert result.exit_code == 0
    assert "Started tracking: coding" in result.stdout
    assert "Worker: Dan-Claude" in result.stdout

    result = runner.invoke(cli, [
        "stop", "--who", "Dan-Claude"
    ])
    assert result.exit_code == 0
    assert "Stopped: coding" in result.stdout

def test_parallel_tracking(temp_tracking_dir):
    """Test two workers tracking simultaneously"""
    # Start both workers
    runner.invoke(cli, ["start", "DD1310"])
    runner.invoke(cli, [
        "start", "coding", "--who", "Dan-Claude"
    ])

    # Stop one worker doesn't affect the other
    result = runner.invoke(cli, [
        "stop", "--who", "Dan-Claude"
    ])
    assert result.exit_code == 0
    assert "All tracking stopped" in result.stdout

    # Default worker still active
    result = runner.invoke(
        cli, ["status", "--who", default_username]
    )
    assert result.exit_code == 0
    assert "DD1310" in result.stdout

    runner.invoke(cli, ["stop"])

def test_status_shows_all_workers(temp_tracking_dir):
    """Test status without --who lists all active workers"""
    runner.invoke(cli, ["start", "DD1310"])
    runner.invoke(cli, [
        "start", "coding", "--who", "Dan-Claude"
    ])

    result = runner.invoke(cli, ["status"])
    assert result.exit_code == 0
    suffix = sanitize_who(default_username)
    assert suffix in result.stdout
    assert "dan-claude" in result.stdout
    assert "DD1310" in result.stdout
    assert "coding" in result.stdout

def test_stats_with_who_filter(temp_tracking_dir):
    """Worker filters apply before daily grouping."""
    today = datetime.datetime.now().date().isoformat()
    runner.invoke(cli, [
        "add", "DD1310", "--duration", "1",
        "--at", f"{today} 09:00"
    ])
    runner.invoke(cli, [
        "add", "coding", "--duration", "1.5",
        "--who", "Dan-Claude",
        "--at", f"{today} 11:00"
    ])

    # Stats for Dan-Claude only
    result = runner.invoke(cli, [
        "stats", "--who", "Dan-Claude"
    ])
    assert result.exit_code == 0
    assert "coding" in result.stdout
    assert "1h 30m 0s" in result.stdout
    assert "DD1310" not in result.stdout

    # Stats for default worker only
    result = runner.invoke(
        cli, ["stats", "--who", default_username]
    )
    assert result.exit_code == 0
    assert "DD1310" in result.stdout
    assert "1h 0m 0s" in result.stdout
    assert "coding" not in result.stdout

