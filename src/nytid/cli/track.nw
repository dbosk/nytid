Cleanup belongs next to construction because the temporary bash init
file or zsh [[ZDOTDIR]] directory must be removed by both callers.

<<helper functions>>=
def cleanup_prompted_shell_command(
    prompt_file: Optional[str],
    prompt_dir: Optional[str],
) -> None:
    """Remove temporary prompt artifacts for prefixed shells."""
    if prompt_file is not None:
        try:
            os.unlink(prompt_file)
        except OSError:
            pass

    if prompt_dir is not None:
        try:
            os.unlink(
                os.path.join(prompt_dir, ".zshrc")
            )
        except OSError:
            pass
        try:
            os.rmdir(prompt_dir)
        except OSError:
            pass


