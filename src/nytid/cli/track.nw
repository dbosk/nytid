Detached tmux launches need two extra pieces of coordination beyond the
normal subprocess case.  First, each launch needs a unique channel name
so the parent can wait for the correct completion signal.  Second, the
child needs an atomic guard file so completion is recorded exactly once
even if multiple cleanup paths race.  The helper functions below provide
those two mechanisms.

<<helper functions>>=
def make_tmux_channel(prefix: str) -> str:
    """Return a unique tmux wait-for channel name."""
    return (
        f"nytid-{prefix}-"
        f"{os.getpid()}-{time.time_ns()}"
    )


def make_tmux_completion_guard(
    status_file: Optional[str],
) -> Optional[str]:
    """Return the atomic completion guard path."""
    if status_file is None:
        return None
    return status_file + ".guard"


def build_tmux_completion_shell(
    *,
    status_file: Optional[str] = None,
    wait_channel: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
    completion_guard: Optional[str] = None,
    status_arg: str,
    signal_arg: str,
) -> str:
    """Return shell code for one-shot tmux completion."""
    shell_commands = []

    if status_file is not None:
        shell_commands.append(
            "printf 'status=%s\\nsignal=%s\\n' "
            f"{status_arg} {signal_arg} "
            f"> {shlex.quote(status_file)}"
        )
    if on_exit_shell is not None:
        shell_commands.append(on_exit_shell)
    if wait_channel is not None:
        shell_commands.append(
            "tmux wait-for -S " + shlex.quote(wait_channel)
        )

    body = "; ".join(shell_commands) or ":"
    if completion_guard is None:
        return body
    return (
        f"if mkdir {shlex.quote(completion_guard)} 2>/dev/null; then "
        f"{body}; "
        "fi"
    )


def build_tmux_wait_wrapper(
    command_args: List[str],
    ready_channel: str,
    *,
    status_file: Optional[str] = None,
    wait_channel: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
    completion_guard: Optional[str] = None,
) -> List[str]:
    """Return a wrapper that waits and records normal exit."""
    script_parts = [
        f"tmux wait-for {shlex.quote(ready_channel)} || exit $?",
        '"$@"',
        "status=$?",
    ]
    completion_shell = build_tmux_completion_shell(
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
        status_arg='"$status"',
        signal_arg="''",
    )
    if completion_shell != ":":
        script_parts.append(completion_shell)
    script_parts.append('exit "$status"')
    return [
        "/bin/sh",
        "-c",
        "; ".join(script_parts),
        "sh",
    ] + command_args


def build_tmux_hook_command(
    *,
    status_file: Optional[str] = None,
    wait_channel: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
    completion_guard: Optional[str] = None,
) -> str:
    """Build the tmux hook command for abnormal pane exit."""
    shell_command = build_tmux_completion_shell(
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
        status_arg=shlex.quote("#{pane_dead_status}"),
        signal_arg=shlex.quote("#{pane_dead_signal}"),
    )
    if shell_command == ":":
        return ""
    return "run-shell " + shlex.quote(shell_command)
@

When tmux splits a pane, the new pane inherits pane-scoped
options---including our exit hooks.  Without a guard, closing
\emph{any} descendant pane would stop tracking, even if the
original tracked pane is still alive.

The same inheritance bug affects [[new-window]]: creating a window
with \texttt{\^{}b c} while focused on the tracked pane causes the
new pane to inherit the exit hooks.  When that new window closes,
tmux has already selected a new active window (typically the tracked
one).  A format-string guard like [[#{==:#{pane_id},%42}]] fails
here because [[#{pane_id}]] resolves to the \emph{currently active}
pane---not the pane that triggered the event---so the guard
passes and tracking stops.

Instead of comparing pane IDs, we ask the semantically correct
question: is the tracked pane still alive?  We use
[[tmux display-message -t]] targeting the tracked pane; the command
fails (non-zero exit) when the pane no longer exists.  With the
leading~[[!]], the hook body only fires when the tracked pane is
dead.

This approach is correct across all exit paths:
\begin{description}
\item[Normal exit]  The wrapper script
  ([[build_tmux_wait_wrapper]]) runs the [[on_exit_shell]]
  \emph{before} the pane exits, so the wrapper handles cleanup.
  When the pane subsequently dies and the hook fires, the tracked
  pane is dead, so the guard lets the hook run---but
  [[_stop-detached]] uses [[quiet_if_missing]], making the
  duplicate invocation harmless.
\item[Abnormal exit]  When the pane is killed (e.g.\@ via
  [[kill-pane]]), the wrapper never executes its cleanup.  The
  [[pane-exited]]/[[pane-died]] hooks fire, the tracked pane is
  dead, and the guard lets the hook stop tracking.
\item[Spurious firing]  When a \emph{different} pane exits (via
  inheritance from [[split-window]] or the [[new-window]] bug),
  the tracked pane is still alive, so
  [[tmux display-message -t]] succeeds and the guard suppresses
  the hook.
\end{description}

For pane [[%42]] the resulting hook is:
\begin{quote}
\small [[if-shell '! tmux display-message -p -t %42 ""
  2>/dev/null' { run-shell '...' }]]
\end{quote}

<<helper functions>>=
def install_tmux_exit_hooks(
    pane_id: str,
    hook_command: str,
) -> None:
    """Install pane exit hooks for a newly created pane.

    The hook is wrapped in an ``if-shell`` guard that checks
    whether the tracked pane still exists, so that hooks
    inherited by split panes or (due to a tmux bug) by
    new-window panes are no-ops.
    """
    if not hook_command:
        return
    guarded_command = (
        "if-shell "
        f"'! tmux display-message -p -t {pane_id}"
        f' "" 2>/dev/null\' '
        f"{{ {hook_command} }}"
    )
    for hook_name in ("pane-exited", "pane-died"):
        subprocess.run(
            [
                "tmux",
                "set-hook",
                "-p",
                "-t",
                pane_id,
                hook_name,
                guarded_command,
            ],
            check=True,
        )


def parse_tmux_exit_status(text: str) -> int:
    """Parse tmux hook status text into a shell exit code."""
    data = {}
    for line in text.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        data[key] = value

    signal_str = data.get("signal", "")
    if signal_str:
        return 128 + int(signal_str)

    status_str = data.get("status", "")
    if status_str:
        return int(status_str)

    return 1


def read_tmux_exit_status(status_file: str) -> int:
    """Read the exit code recorded by the tmux hook."""
    try:
        with open(status_file) as f:
            return parse_tmux_exit_status(f.read())
    except OSError:
        return 1


def run_tmux_command(
    command_args: List[str],
    *,
    cwd: str,
    env: Dict[str, str],
    window: bool = False,
    window_name: Optional[str] = None,
    block: bool = True,
    exit_status_file: Optional[str] = None,
    on_exit_shell: Optional[str] = None,
    focus_labels: Optional[List[str]] = None,
    focus_who: Optional[str] = None,
    focus_window: bool = False,
) -> Optional[int]:
    """Run a command in tmux and optionally wait for exit.

    When ``focus_labels`` is set, auto-suspend hooks are
    installed.  Pane launches suspend directly on pane focus
    changes, while window launches use pane-focus hooks as
    sensors plus the deferred window event buffer.
    """
    ready_channel = make_tmux_channel("ready")
    wait_channel = None
    status_file = exit_status_file
    pane_id = None
    window_id = None
    session_id = None
    remove_status_file = False
    completion_guard = None
    tmux_server_key = None

    if block and status_file is None:
        fd, status_file = tempfile.mkstemp(
            prefix="nytid-tmux-",
            suffix=".status",
        )
        os.close(fd)
        remove_status_file = True
    if block:
        wait_channel = make_tmux_channel("done")
        completion_guard = make_tmux_completion_guard(
            status_file
        )

    wrapped_command = build_tmux_wait_wrapper(
        command_args,
        ready_channel,
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
    )

    hook_command = build_tmux_hook_command(
        status_file=status_file,
        wait_channel=wait_channel,
        on_exit_shell=on_exit_shell,
        completion_guard=completion_guard,
    )

    tmux_args = [
        "tmux",
        "new-window" if window else "split-window",
        "-P",
        "-F",
        "#{pane_id} #{window_id} #{session_id}",
    ]
    for key, value in sorted(env.items()):
        tmux_args.extend([
            "-e",
            f"{key}={value}",
        ])
    if window and window_name:
        tmux_args.extend(["-n", window_name])
    tmux_args.extend([
        "-c",
        cwd,
    ])
    tmux_args.append(shlex.join(wrapped_command))

    old_sigint = None
    if block:
        old_sigint = signal.signal(
            signal.SIGINT, signal.SIG_IGN
        )

    try:
        socket_path = parse_tmux_socket_path(
            env.get("TMUX")
        )
        if socket_path:
            tmux_server_key = build_tmux_server_key(
                socket.gethostname(), socket_path,
            )
        <<launch tmux command and install hooks>>
        subprocess.run(
            ["tmux", "wait-for", "-S", ready_channel],
            check=True,
        )
        if not block:
            return None
        subprocess.run(
            ["tmux", "wait-for", wait_channel],
            check=True,
        )
        return read_tmux_exit_status(status_file)
    except Exception:
        if pane_id:
            try:
                subprocess.run(
                    ["tmux", "kill-pane", "-t", pane_id],
                    check=False,
                )
            except OSError:
                pass
        raise
    finally:
        if block and old_sigint is not None:
            signal.signal(signal.SIGINT, old_sigint)
        if remove_status_file and status_file is not None:
            try:
                os.unlink(status_file)
            except OSError:
                pass
        if completion_guard is not None:
            try:
                os.rmdir(completion_guard)
            except OSError:
                pass
