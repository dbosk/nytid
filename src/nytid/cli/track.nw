\subsection{Stop Command}

The stop command ends tracking for labels. By default, it stops the most recently
started label (LIFO - Last In, First Out). This allows progressive unwinding of
tracking sessions. You can also stop specific labels or use [[--all]] to stop
everything at once.

This LIFO behavior is useful when tracking nested contexts, like starting with a
course label, then adding an activity label. Repeated [[stop]] commands naturally
unwind in reverse order.

<<argument and option definitions>>=
labels_opt_arg = typer.Argument(
    help="Specific labels to stop",
    autocompletion=complete_active_labels)
all_labels_opt = typer.Option(
    "--all", "-a",
    help="Stop all active labels")
@

<<stop command>>=
@cli.command()
def stop(
    labels: Annotated[Optional[List[str]],
                      labels_opt_arg] = None,
    all_labels: Annotated[bool,
                          all_labels_opt] = False,
    offset: Annotated[Optional[str],
                      offset_opt] = None,
    at: Annotated[Optional[str], at_opt] = None,
    who: Annotated[str, who_opt] = default_username,
):
    """
    Stop tracking for the current batch, specific labels, or everything.

    Use the default form to unwind the most recent context, name labels when
    only part of the session should stop, or backdate the stop time after
    forgetting to stop on time.

    \b
    Examples:
      nytid track stop
      nytid track stop --all
      nytid track stop DD1310
      nytid track stop DD1310 lecture
      nytid track stop --offset -30m
      nytid track stop --at 16:00
    """
    # Check for conflicting options
    if offset is not None and at is not None:
        typer.echo(
            "Error: Cannot use both --offset and "
            "--at options", err=True
        )
        raise typer.Exit(1)

    # Calculate end time
    end_time = datetime.datetime.now()

    if at is not None:
        try:
            end_time = parse_at_time(at)
        except ValueError as e:
            typer.echo(f"Error: {e}", err=True)
            raise typer.Exit(1)
    elif offset is not None:
        try:
            offset_delta = parse_offset(offset)
            end_time += offset_delta
        except ValueError as e:
            typer.echo(
                f"Error parsing offset '{offset}': {e}",
                err=True
            )
            raise typer.Exit(1)

    try:
        session, completed_entries = stop_tracking_labels(
            who=who,
            labels=labels,
            all_labels=all_labels,
            end_time=end_time,
        )
    except ValueError as exc:
        typer.echo(str(exc), err=True)
        raise typer.Exit(1)

    # Display what was completed
    for entry in completed_entries:
        typer.echo(
            f"Stopped: "
            f"{get_labels_display(entry.labels)} "
            f"({format_duration(entry.duration())})"
        )

    # Show remaining active labels
    if session.is_active():
        remaining = session.get_active_labels()
        typer.echo(
            f"Still tracking: {', '.join(remaining)}"
        )
    else:
        typer.echo("All tracking stopped")

    # Show time information if not current time
    if at is not None or offset is not None:
        typer.echo(
            f"Stop time: "
            f"{end_time.strftime('%Y-%m-%d %H:%M:%S')}"
        )

@

