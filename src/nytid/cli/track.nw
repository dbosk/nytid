    assert "Duration must be positive" in result.stdout

def test_add_with_offset(temp_tracking_dir):
    """--offset backdates the start of an added entry."""
    result = runner.invoke(cli, [
        "add", "meeting",
        "--duration", "30m",
        "--offset", "-60m"
    ])
    assert result.exit_code == 0
    assert "Added entry: meeting" in result.stdout
    # Start time should be ~60 min ago, end ~30 min ago.
    entries = load_tracking_data()
    assert len(entries) == 1
    delta_start = datetime.datetime.now() - entries[0].start_time
    delta_end = datetime.datetime.now() - entries[0].end_time
    assert 55 * 60 < delta_start.total_seconds() < 65 * 60
    assert 25 * 60 < delta_end.total_seconds() < 35 * 60

def test_add_with_at_time(temp_tracking_dir):
    """--at sets an explicit start time for an added entry."""
    result = runner.invoke(cli, [
        "add", "meeting",
        "--duration", "45m",
        "--at", "2024-06-15 10:00"
    ])
    assert result.exit_code == 0
    entries = load_tracking_data()
    assert len(entries) == 1
    assert entries[0].start_time == datetime.datetime(2024, 6, 15, 10, 0)
    assert entries[0].end_time == datetime.datetime(2024, 6, 15, 10, 45)

def test_add_offset_and_at_are_exclusive(temp_tracking_dir):
    """Using both --offset and --at together is an error."""
    result = runner.invoke(cli, [
        "add", "meeting",
