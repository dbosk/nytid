    bindir = tmp_path / "bin"
    bindir.mkdir()
    nytid_path = bindir / "nytid"
    nytid_path.write_text("#!/bin/sh\n")
    with patch.object(sys, "argv", ["pytest"]), patch.object(
        sys, "executable", str(bindir / "python")
    ), patch("nytid.cli.track.shutil.which", return_value=None):
        prefix = build_detached_nytid_prefix()
    assert prefix == f"{nytid_path} track"

def test_build_detached_nytid_prefix_falls_back_to_path_lookup():
    """Resolve nytid from PATH when the current process is not nytid."""
    with patch.object(sys, "argv", ["pytest"]), patch.object(
        sys, "executable", "/tmp/venv/bin/python"
    ), patch("nytid.cli.track.shutil.which", return_value="/tmp/nytid"):
        prefix = build_detached_nytid_prefix()
    assert prefix == "/tmp/nytid track"

def test_build_detached_nytid_prefix_requires_resolvable_nytid():
    """Fail clearly when no nytid entrypoint can be resolved."""
    with patch.object(sys, "argv", ["pytest"]), patch.object(
        sys, "executable", "/tmp/venv/bin/python"
    ), patch("nytid.cli.track.shutil.which", return_value=None):
        with pytest.raises(RuntimeError, match="nytid"):
            build_detached_nytid_prefix()

def test_build_tmux_server_key_changes_with_host_or_socket():
    """Server key distinguishes host/socket combinations."""
    assert build_tmux_server_key("a", "/tmp/x") != \
        build_tmux_server_key("b", "/tmp/x")
    assert build_tmux_server_key("a", "/tmp/x") != \
