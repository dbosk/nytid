The tracked-window launch path holds the tmux-context lock only across
the narrow hook-observability phase: [[new-window]], label publication,
and the [[last_selected_window]] write.  It explicitly releases the
lock before [[seed_window_event_buffer]] and the window sync/cleanup
hook installs, because the seed self-triggers
[[start_tracking_labels]] which re-acquires the same lock through
[[mutate_worker_tracking_state]] and would otherwise self-deadlock.

<<test functions>>=
def test_run_tmux_command_locks_window_launch_setup(
    temp_tracking_dir,
):
    """Lock covers only the hook-observability phase."""
    events = []

    def fake_with_tmux_context_lock(callback):
        events.append("lock-enter")
        try:
            return callback()
        finally:
            events.append("lock-exit")

    def fake_subprocess_run(args, **kwargs):
        if args[:2] == ["tmux", "new-window"]:
            events.append("new-window")
            class Result:
                stdout = "%42 @7 $9\n"
            return Result()
        if args[:4] == ["tmux", "wait-for", "-S", "ready-chan"]:
            events.append("ready")
            class Result:
                stdout = ""
            return Result()
        events.append(tuple(args[:2]))
        class Result:
            stdout = ""
        return Result()

    with patch(
        "nytid.cli.track.make_tmux_channel",
        side_effect=["ready-chan"],
    ), patch(
        "nytid.cli.track.parse_tmux_socket_path",
        return_value="/tmp/tmux.sock",
    ), patch(
        "nytid.cli.track.build_tmux_server_key",
        return_value=TEST_SERVER_KEY,
    ), patch(
        "nytid.cli.track.with_tmux_context_lock",
        side_effect=fake_with_tmux_context_lock,
    ), patch(
        "nytid.cli.track.subprocess.run",
        side_effect=fake_subprocess_run,
    ), patch(
        "nytid.cli.track.install_tmux_exit_hooks",
        side_effect=lambda *args, **kwargs:
        events.append("exit-hooks"),
    ), patch(
        "nytid.cli.track.write_window_labels",
        side_effect=lambda *args, **kwargs:
        events.append("write-labels"),
    ), patch(
        "nytid.cli.track.read_last_selected_window",
        return_value=None,
    ), patch(
        "nytid.cli.track.read_window_labels",
        return_value=None,
    ), patch(
        "nytid.cli.track.write_last_selected_window",
        side_effect=lambda *args, **kwargs:
        events.append("write-last-selected"),
    ), patch(
        "nytid.cli.track.seed_window_event_buffer",
        side_effect=lambda *args, **kwargs:
        events.append("seed"),
    ), patch(
        "nytid.cli.track.install_tmux_window_sync_hooks",
        side_effect=lambda *args, **kwargs:
        events.append("sync-hooks"),
    ), patch(
        "nytid.cli.track.install_tmux_window_cleanup_hook",
        side_effect=lambda *args, **kwargs:
        events.append("cleanup-hook"),
    ):
        result = run_tmux_command(
            ["/bin/bash"],
            cwd="/tmp",
            env={"TMUX": "client,1,0"},
            window=True,
            window_name="track:work",
            block=False,
            focus_labels=["work"],
            focus_who="me",
            focus_window=True,
        )

    assert result is None
    assert events == [
        "lock-enter",
        "new-window",
        "exit-hooks",
        "write-labels",
        "write-last-selected",
        "lock-exit",
        "seed",
        "sync-hooks",
        "cleanup-hook",
        "ready",
    ]

