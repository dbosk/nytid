@

To preserve accurate timings through the deferred buffer, [[stop]] and
[[start]] event lines carry the hook timestamp explicitly instead of
borrowing the later execution time.  Those lines now also carry the tmux
[[window_id]] they describe.  The [[window-switch]] markers likewise carry
the tracked/untracked state together with the source and target window
IDs.  With those IDs in hand, the matcher can look for the stop that
belongs to the source window and the start that belongs to the target
window, instead of guessing from the last stop/start lines in the file.

<<helper functions>>=
def build_window_event_line(
    action: str,
    labels: List[str],
    when: Optional[datetime.datetime] = None,
    window_id: Optional[str] = None,
) -> str:
    """Return one deferred stop/start event line."""
    if when is None:
        when = datetime.datetime.now()
    parts = [action, when.isoformat()]
    if window_id is not None:
        parts.append(f"window={window_id}")
    parts.extend(labels)
    return " ".join(parts)


def build_window_switch_event_line(
    target_tracked: bool,
    source_tracked: Optional[bool] = None,
    source_window_id: Optional[str] = None,
    target_window_id: Optional[str] = None,
) -> str:
    """Return one deferred window-switch marker line."""
    parts = [
        "window-switch",
        "tracked" if target_tracked else "untracked",
    ]
    if source_tracked is not None:
        parts.append(
            "from-tracked"
            if source_tracked
            else "from-untracked"
        )
    if source_window_id is not None:
        parts.append(f"source={source_window_id}")
    if target_window_id is not None:
        parts.append(f"target={target_window_id}")
    return " ".join(parts)


def parse_window_event_line(line: str) -> dict:
    """Parse one deferred buffer line into structured fields."""
    if line.startswith("window-switch "):
        parts = line.split()
        result = {
            "kind": "window-switch",
            "raw": line,
            "target_tracked": parts[1] == "tracked",
            "source_tracked": None,
            "source_window_id": None,
            "target_window_id": None,
        }
        for token in parts[2:]:
            if token == "from-tracked":
                result["source_tracked"] = True
            elif token == "from-untracked":
                result["source_tracked"] = False
            elif token.startswith("source="):
                result["source_window_id"] = (
                    token.split("=", 1)[1] or None
                )
            elif token.startswith("target="):
                result["target_window_id"] = (
                    token.split("=", 1)[1] or None
                )
        return result

    parts = line.split()
    if not parts:
        return {"kind": "unknown", "raw": line}
    if parts[0] not in {"stop", "start"}:
        return {"kind": "unknown", "raw": line}

    tokens = parts[1:]
    when = None
    if tokens:
        try:
            when = datetime.datetime.fromisoformat(tokens[0])
            tokens = tokens[1:]
        except ValueError:
            pass

    window_id = None
    if tokens and tokens[0].startswith("window="):
        window_id = tokens[0].split("=", 1)[1] or None
        tokens = tokens[1:]

    return {
        "kind": parts[0],
        "raw": line,
        "when": when,
        "labels": tokens,
        "window_id": window_id,
    }
@

The matcher now consumes one coherent switch transaction rather than
counting the whole file and taking whichever stop/start happened to be
last.  We still keep the original on-disk buffer, but we normalize the
parsed view before matching:

\begin{description}
\item[Duplicate switch markers]
  Adjacent [[window-switch]] lines with the same source, target, and
  tracked-state annotations describe one tmux switch, so later matching
  should not treat them as separate transactions.
\item[Alt-Tab blur pairs]
  A plain terminal blur produces [[stop]] followed by [[start]] for the
  same window and no switch marker.  Those two lines cancel out as noise:
  they must not later be reused as the target start for an unrelated
  window switch.
\item[Nearest matching edges]
  Once the noise is collapsed away, the matcher scans backward for the
  newest [[window-switch]] marker whose required source [[stop]] and
  target [[start]] edges can be found for the windows named in that
  marker.
\end{description}

We keep a legacy fallback for older buffers that lack window metadata.
That preserves compatibility with historical [[window-switch tracked]]
markers while routing all new tmux-generated lines through the stricter
window-aware matcher.

<<helper functions>>=
def window_event_has_metadata(event: dict) -> bool:
    """Return whether a parsed deferred event carries window metadata."""
    if event["kind"] in {"stop", "start"}:
        return event.get("window_id") is not None
    if event["kind"] == "window-switch":
        return (
            event.get("source_window_id") is not None
            or event.get("target_window_id") is not None
        )
    return False


def is_duplicate_window_switch_event(
    previous: dict,
    current: dict,
) -> bool:
    """Return whether two adjacent switch markers describe one switch."""
    return (
        previous["kind"] == "window-switch"
        and current["kind"] == "window-switch"
        and previous["target_tracked"] == current["target_tracked"]
        and previous["source_tracked"] == current["source_tracked"]
        and previous.get("source_window_id")
        == current.get("source_window_id")
        and previous.get("target_window_id")
        == current.get("target_window_id")
    )


def is_window_blur_pair(previous: dict, current: dict) -> bool:
    """Return whether adjacent stop/start lines cancel as blur noise."""
    return (
        previous["kind"] == "stop"
        and current["kind"] == "start"
        and previous.get("window_id") is not None
        and previous.get("window_id") == current.get("window_id")
    )


def normalize_window_event_buffer(lines: List[str]) -> List[dict]:
    """Collapse duplicate switch markers and blur pairs."""
    events = []
    for line in lines:
        event = parse_window_event_line(line)
        if (
            events
            and is_duplicate_window_switch_event(
                events[-1], event,
            )
        ):
            continue
        if events and is_window_blur_pair(events[-1], event):
            events.pop()
            continue
        events.append(event)
    return events


def find_nearest_window_event(
    events: List[dict],
    switch_index: int,
    kind: str,
    window_id: Optional[str],
) -> Optional[dict]:
    """Return the closest buffered event for ``window_id``."""
    if window_id is None:
        return None
    for offset in range(1, len(events) + 1):
        right_index = switch_index + offset
        if right_index < len(events):
            event = events[right_index]
            if (
                event["kind"] == kind
                and event.get("window_id") == window_id
            ):
                return event

        left_index = switch_index - offset
        if left_index >= 0:
            event = events[left_index]
            if (
                event["kind"] == kind
                and event.get("window_id") == window_id
            ):
                return event
    return None


def find_legacy_window_event_transition(
    events: List[dict],
) -> Optional[dict]:
    """Return one executable transition for legacy buffer lines."""
    stop_count = 0
    start_count = 0
    switch_target_tracked = None
    switch_source_tracked = None
    last_stop_event = None
    last_start_event = None

    for event in events:
        if event["kind"] == "stop":
            stop_count += 1
            last_stop_event = event
        elif event["kind"] == "start":
            start_count += 1
            last_start_event = event
        elif event["kind"] == "window-switch":
            switch_target_tracked = event["target_tracked"]
            switch_source_tracked = event["source_tracked"]

    switch = {
        "target_tracked": switch_target_tracked,
        "source_tracked": switch_source_tracked,
    }
    if (
        switch_target_tracked is True
        and stop_count == start_count
        and stop_count > 0
    ):
        return {
            "execution": "switch",
            "switch": switch,
            "stop_event": last_stop_event,
            "start_event": last_start_event,
        }
    if (
        switch_target_tracked is False
        and stop_count == start_count + 1
    ):
        return {
            "execution": "stop",
            "switch": switch,
            "stop_event": last_stop_event,
            "start_event": None,
        }
    if (
        switch_target_tracked is True
        and start_count == stop_count + 1
        and switch_source_tracked is not True
    ):
        return {
            "execution": "start",
            "switch": switch,
            "stop_event": None,
            "start_event": last_start_event,
        }
    return None


def find_window_event_transition(lines: List[str]) -> Optional[dict]:
    """Return one executable deferred transition from ``lines``."""
    events = normalize_window_event_buffer(lines)
    if not events:
        return None

    if not any(
        window_event_has_metadata(event)
        for event in events
    ):
        return find_legacy_window_event_transition(events)

    for switch_index in range(len(events) - 1, -1, -1):
        switch = events[switch_index]
        if switch["kind"] != "window-switch":
            continue

        stop_event = None
        if switch["source_tracked"] is True:
            stop_event = find_nearest_window_event(
                events,
                switch_index,
                "stop",
                switch.get("source_window_id"),
            )
            if stop_event is None:
                continue

        start_event = None
        if switch["target_tracked"] is True:
            start_event = find_nearest_window_event(
                events,
                switch_index,
                "start",
                switch.get("target_window_id"),
            )
            if start_event is None:
                continue

        if switch["target_tracked"] is False:
            execution = "stop"
        elif switch["source_tracked"] is not True:
            execution = "start"
        else:
            execution = "switch"

        return {
            "execution": execution,
            "switch": switch,
            "stop_event": stop_event,
            "start_event": start_event,
        }

    return None
@

The main diagnostic emitter writes to the log file and optionally sends
a desktop notification via [[notify-send]].  Missing [[notify-send]] is
silently ignored because the file log is the primary record.

<<helper functions>>=
def emit_window_event_debug(
    who: str,
    tmux_server_key: str,
    session_id: str,
    action: str,
    event_line: str,
    buffer_text: str = "",
    notify: bool = True,
    notification_body: Optional[str] = None,
) -> None:
    """Emit env-gated diagnostics for the deferred window buffer."""
    if not track_debug_enabled():
        return

    ensure_tracking_dir()
    timestamp = datetime.datetime.now().isoformat(sep=" ")
    buffer_snapshot = buffer_text.replace("\n", " | ").strip()
    log_line = (
        f"{timestamp} pid={os.getpid()} who={who} "
        f"server={tmux_server_key} session={session_id} "
        f"action={action} event={event_line!r} "
        f"buffer={buffer_snapshot!r}\n"
    )
    with open(window_event_debug_log_path(), "a") as handle:
        handle.write(log_line)

    if not notify:
        return

    body = notification_body or (
        f"action: {action}\n"
        f"event: {event_line}\n"
        f"who: {who}\n"
        f"session: {session_id}\n"
        f"buffer: {buffer_snapshot or '(empty)'}"
    )
    try:
        subprocess.run(
            ["notify-send", "nytid track debug", body],
            check=False,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            env=os.environ.copy(),
        )
    except FileNotFoundError:
        pass
@

The core logic appends one event line and then checks the trigger
condition while holding the buffer's file lock.  We split this into
two layers so that more than one append can happen under a single
[[flock]] transaction:

\begin{description}
\item[Inner body]
  [[_process_window_event_locked]] assumes the file descriptor is
  already open and locked.  It performs the append, parses the full
  buffer, checks the trigger condition, executes the deferred
  transition on a match, and (on a match) truncates the buffer so
  subsequent calls within the same locked transaction start from an
  empty file.  This body can therefore be invoked repeatedly under
  one lock hold, building up a multi-line fact set whose final
  append fires the trigger.
\item[Single-line wrapper]
  [[append_and_check_window_event]] is what the tmux hook
  subprocesses call.  It keeps the original public signature, opens
  the buffer, acquires the lock, delegates to the inner body for
  exactly one line, and releases.
\item[Seed wrapper]
  [[seed_window_event_buffer]] is the entry point
  [[run_tmux_command]] uses when creating a new tracked window.  It
  acquires the lock \emph{once}, truncates the buffer under the lock
  to discard anything earlier hook subprocesses deposited, then
  feeds its seed lines one at a time through the inner body, still
  under the same lock, and releases only after the final append has
  had a chance to fire the trigger.
\end{description}

Holding one lock across the whole seed transaction is essential:
splitting the seed into separate [[append_and_check_window_event]]
calls would release the lock between lines, letting a concurrent
hook subprocess squeeze in its own [[window-switch]] marker or a
stray [[stop]] between the seed's [[start]] and its marker, and
fire the trigger on a half-built fact set.

Concurrent hook subprocesses are blocked, not lost.
[[fcntl.flock]] with [[LOCK_EX]] blocks (we never pass
[[LOCK_NB]]), so any hook fired during the seed's lock-hold simply
waits in its own [[flock]] call until the seed releases.  Tmux
[[run-shell]] processes have no timeout, so a queued hook just
keeps waiting; no event is dropped by the buffer lock itself.

New-window launches also use the tmux-context lock.  [[run_tmux_command]]
holds that lock from the [[tmux new-window]] invocation through label
publication, [[last_selected_window]] update, seeding, and hook
installation.  That earlier lock serializes the seed against any
detached [[session-window-changed]] hook spawned by [[new-window]], so a
hook cannot snapshot stale context state and then append an obsolete
marker after the seed releases the buffer lock.

The trigger condition still waits for a real [[window-switch]] marker,
but it no longer executes by comparing global stop/start counts.  The
matcher first collapses same-window blur pairs and duplicate switch
markers, then searches backward for the newest switch whose required
source [[stop]] and target [[start]] edges can be matched to the window
IDs recorded in that marker.  Once such a switch is found, we execute the
deferred transition and truncate the file.

<<helper functions>>=
def _process_window_event_locked(
    fd: int,
    who: str,
    tmux_server_key: str,
    session_id: str,
    event_line: str,
) -> None:
    """Append one event line and fire the trigger if ready.

    The caller must have already opened ``fd`` and acquired an
    exclusive ``fcntl.flock`` on it.  On a successful trigger this
    function truncates the buffer so subsequent appends within the
    same locked transaction start from an empty file.
    """
    <<append event line>>
    <<check trigger condition>>
@

<<helper functions>>=
def append_and_check_window_event(
    who: str,
    tmux_server_key: str,
    session_id: str,
    event_line: str,
) -> None:
    """Append an event line and execute if the trigger condition is met.

    This is the single-line entry point used by the tmux hook
    subprocesses.  It opens the buffer, acquires an exclusive
    ``fcntl.flock``, delegates to
    ``_process_window_event_locked`` for exactly one line, and
    releases the lock.
    """
    ensure_tracking_dir()
    path = window_event_buffer_path(
        who, tmux_server_key, session_id,
    )
    fd = os.open(
        str(path),
        os.O_RDWR | os.O_CREAT,
        0o644,
    )
    try:
        fcntl.flock(fd, fcntl.LOCK_EX)
        _process_window_event_locked(
            fd, who, tmux_server_key,
            session_id, event_line,
        )
    finally:
        fcntl.flock(fd, fcntl.LOCK_UN)
        os.close(fd)
@

The seed entry point holds one [[flock]] across a truncate followed
by a sequence of inner-body calls.  Holding the lock for the entire
transaction prevents any concurrent tmux hook subprocess from
interleaving lines into the buffer between the seed's truncate and
its final append.  Any hook fired during the seed simply blocks on
its own [[flock]] call and observes the post-seed buffer state once
the seed releases---either empty (when the seed's final append
triggered the deferred-switch execution) or holding exactly the seed
lines the caller supplied.

<<helper functions>>=
def seed_window_event_buffer(
    who: str,
    tmux_server_key: str,
    session_id: str,
    event_lines: List[str],
) -> None:
    """Atomically reset the buffer and apply a sequence of seed lines.

    Holds one exclusive ``fcntl.flock`` across an initial
    ``os.ftruncate`` and one
    ``_process_window_event_locked`` call per line in
    ``event_lines``, preventing concurrent hook subprocesses from
    interleaving into the seed transaction.
    """
    ensure_tracking_dir()
    path = window_event_buffer_path(
        who, tmux_server_key, session_id,
    )
    fd = os.open(
        str(path),
        os.O_RDWR | os.O_CREAT,
        0o644,
    )
    try:
        fcntl.flock(fd, fcntl.LOCK_EX)
        os.ftruncate(fd, 0)
        for line in event_lines:
            _process_window_event_locked(
                fd, who, tmux_server_key,
                session_id, line,
            )
    finally:
        fcntl.flock(fd, fcntl.LOCK_UN)
        os.close(fd)
@

Appending seeks to the end so that existing content is preserved:

<<append event line>>=
os.lseek(fd, 0, os.SEEK_END)
os.write(fd, (event_line + "\n").encode())
os.fsync(fd)
