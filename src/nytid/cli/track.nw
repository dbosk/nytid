\paragraph{Suspend reads from pane labels file.}
After the refactoring, [[_suspend-detached]] reads which labels to
suspend from the pane labels file rather than receiving them as
command-line arguments.  We verify this by writing a pane labels
file, starting those labels, then invoking the hidden command.

<<test functions>>=
def test_suspend_detached_reads_pane_labels(
    temp_tracking_dir,
):
    """Suspend reads labels from pane labels file."""
    pane_id, who = "%55", default_username
    runner.invoke(cli, ["start", "work", "email"])

    write_pane_labels(
        pane_id, who, TEST_SERVER_KEY,
        ["work", "email"],
    )
    runner.invoke(cli, [
        "_suspend-detached",
        "--pane-id", pane_id,
        "--server-key", TEST_SERVER_KEY,
    ])

    session = load_active_session(who)
    assert session.get_active_labels() == []

    state = read_suspend_state(
        suspend_state_path(
            pane_id, who, TEST_SERVER_KEY,
        ),
    )
    assert sorted(state) == ["email", "work"]

    # Clean up
    resume_tracking_labels(
        who=who,
        pane_id=pane_id,
        tmux_server_key=TEST_SERVER_KEY,
    )
    runner.invoke(cli, ["stop", "--all"])
