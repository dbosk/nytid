<<helper functions>>=
def get_tmux_selected_window_id(
    session_id: str,
) -> Optional[str]:
    """Return the currently selected tmux window for ``session_id``."""
    try:
        result = subprocess.run(
            [
                "tmux",
                "display-message",
                "-p",
                "-t",
                session_id,
                "#{window_id}",
            ],
            capture_output=True,
            text=True,
            check=True,
        )
    except (subprocess.CalledProcessError, OSError):
        return None
    window_id = result.stdout.strip()
    if not window_id:
        return None
    return window_id
