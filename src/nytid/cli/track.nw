command removes only those labels; any labels contributed by surviving
panes in the same tracked window remain untouched.

<<helper functions>>=
def build_detached_window_cleanup_command(
    labels: List[str],
    who: str,
    window_id: str,
    tmux_server_key: str,
) -> str:
    """Return shell command to remove one pane's window labels."""
    prefix = build_detached_nytid_prefix()
    label_args = " ".join(
        shlex.quote(lbl) for lbl in labels
    )
    cmd = (
        f"{prefix} "
        f"_cleanup-window-detached {label_args}"
        f" --window-id {shlex.quote(window_id)}"
        f" --server-key {shlex.quote(tmux_server_key)}"
    )
    if who != default_username:
        cmd += f" --who {shlex.quote(who)}"
    return cmd
